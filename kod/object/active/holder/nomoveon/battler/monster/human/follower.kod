                  iSpell = SID_FORCES_OF_LIGHT;
                  break;
               case FOLLOWER_ROLE_WARLOCK:
                  iSpell = SID_BLIND;
                  break;
            }
            break;

         case 9:
            switch(piRole)
            {
               case FOLLOWER_ROLE_BARD:
                  iSpell = SID_ILLUSIONARY_WOUNDS;
                  break;
               case FOLLOWER_ROLE_WARRIOR:
                  iSpell = SID_KILLING_FIELDS;
                  break;
               case FOLLOWER_ROLE_WIZARD:
                  iSpell = SID_ICE_NOVA;
                  break;
               case FOLLOWER_ROLE_PRIEST:
                  iSpell = SID_DAZZLE;
                  break;
               case FOLLOWER_ROLE_WARLOCK:
                  iSpell = SID_EVIL_TWIN;
                  break;
            }
            break;

         case 10:
            switch(piRole)
            {
               case FOLLOWER_ROLE_BARD:
                  iSpell = SID_ILLUSIONARY_FIREWALL;
                  break;
               case FOLLOWER_ROLE_WARRIOR:
                  iSpell = SID_ARMOR_OF_GORT;
                  break;
               case FOLLOWER_ROLE_WIZARD:
                  iSpell = SID_RING_OF_FLAMES;
                  break;
               case FOLLOWER_ROLE_PRIEST:
                  iSpell = SID_MAJOR_HEAL;
                  break;
               case FOLLOWER_ROLE_WARLOCK:
                  iSpell = SID_REFLECTION;
                  break;
            }
            break;
         default:
            iSpell = 0;
            break;
      }

      return iSpell;
   }

   FollowerLearnMessage(iNum=$)
   {
      local oSpell;

      oSpell = Send(SYS,@FindSpellByNum,#num=iNum);

      Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_learn,
      #parm1=Send(oSpell,@GetName));

      return;
   }

   FollowerSpellInform()
   {
      local i, iNum, oSpell, iSpells, iTotal, iResources, lSpells;

      // Figure the number of spells to pick the according resources.
      lSpells = Send(self,@GetSpellObjects);
      iTotal = Length(lSpells);

      if iTotal = 0
      {
         iResources = 3;
      }
      else
      {
         iResources = 2 * iTotal + 2;
      }

      AddPacket(4,Send(SYS,@AddResourceTemplate,#iNum=iResources),
                4,follower_say_start);

      if iTotal = 0
      {
         AddPacket(4,follower_no_spell_inform);
      }
      else if iTotal = 1
      {
         AddPacket(4,follower_one_spell_inform);
      }
      else
      {
         AddPacket(4,follower_spell_inform);
      }

      iSpells = 0;

      // Actually get the name of each spell and add each individually.
      foreach i in lSpells
      {
         // Add an "and" if we reach the end of our list.
         if (i = Nth(lSpells,iTotal))
            AND iSpells > 0
         {
            AddPacket(4,follower_and);
         }
         else if i <> First(lSpells)
         {
            AddPacket(4,follower_comma);
         }

         AddPacket(4,follower_spell,4,Send(i,@GetName));

         ++iSpells;
      }

      AddPacket(4,follower_say_end);

      return TRUE;
   }

   GetSpellObjects()
   {
      local i, iNum, lSpells;

      foreach i in plActions
      {
         iNum = First(i);

         if iNum < 400
         {
            lSpells = Cons(Send(SYS,@FindSpellByNum,#num=iNum),lSpells);
         }
      }

      return lSpells;
   }

   FollowerAdjustLight()
   {
      local iLight, i, oObject, oSpell, iSpellPower;

      if Send(poLeader,@GetOwner) = poOwner
      {
         iLight = Send(poOwner,@GetRoomLight);
         iLight += Send(poLeader,@GetLightLevel);

         if (iLight >= LIGHT_NICE)
         {
            foreach i in plUsing
            {
               if IsClass(i,&Torch)
               {
                  Send(self,@UnuseItem,#what=i,#bDrop=FALSE);
                  break;
               }
            }

            foreach i in plPassive
            {
               oObject = Send(self,@HolderExtractObject,#data=i);

               if IsClass(oObject,&Shield)
                  AND NOT IsClass(oObject,&Torch)
               {
                  break;
               }
               else
               {
                  oObject = $;
               }
            }

            if oObject <> $
            {
               Send(self,@TryUseItem,#what=oObject);
            }
         }
         else
         {
            oObject = Send(self,@FindHolding,#class=&Torch);

            if (oObject <> $)
               AND (GetListElemByClass(plUsing,&Torch) = $)
            {
               foreach i in plUsing
               {
                  if IsClass(i,&Shield)
                  {
                     Send(self,@UnuseItem,#what=i,#bDrop=FALSE);
                     break;
                  }
               }

               if Send(self,@TryUseItem,#what=oObject)
               {
                  return TRUE;
               }
            }
         }
      }

      return FALSE;
   }

   EnterStateMove()
   {
      local oObject, i, oEnch, state, oInfo, iInfo, iRowDiff, iColDiff,
         iAbsRow, iAbsCol, iLeaderRow, iLeaderCol, iHeight;

      // The following is only relevant if we have a leader.
      // If we don't, chances are we have just been fired and are trying
      // to spend the last ten seconds of our life in a meaningful way.
      // The world is a horrible place, man. :(
      if poLeader <> $
      {
         // If the leader reaches us a hand, we grab it!
         if Send(poLeader,@IsOfferingLift)
         {
            iHeight = Send(poLeader,@GetHeight);

            if (piHeight < iHeight)
               AND (iHeight - piHeight) < 3*FINENESS
               AND (Send(self,@SquaredFineDistanceTo,#what=poLeader) < 4*FINENESS_SQUARED)
               AND Send(poOwner,@LineOfSight,#obj1=self,#obj2=poLeader)
            {
               iLeaderRow = FINENESS * Send(poLeader,@GetRow) + Send(poLeader,@GetFineRow);
               iRowDiff = iLeaderRow - FINENESS * piRow - piFine_row;
               iAbsRow = Bound(Abs(iRowDiff),1,$);
               iLeaderCol = FINENESS * Send(poLeader,@GetCol) + Send(poLeader,@GetFineCol);
               iColDiff = iLeaderCol - FINENESS * piCol - piFine_col;
               iAbsCol = Bound(Abs(iColDiff),1,$);

               if iAbsRow > iAbsCol
               {
                  iRowDiff = iRowDiff * FINENESS / iAbsRow;
                  iColDiff = iColDiff * FINENESS / iAbsRow;
               }
               else
               {
                  iRowDiff = iRowDiff * FINENESS / iAbsCol;
                  iColDiff = iColDiff * FINENESS / iAbsCol;
               }

               // Final desired location in fine units.
               iLeaderRow -= iRowDiff / 3;
               iLeaderCol -= iColDiff / 3;

               if Send(SYS,@UtilGoNearSquare,#what=self,#where=poOwner,
                    #new_row=iLeaderRow/FINENESS,
                    #fine_row=iLeaderRow%FINENESS,
                    #new_col=iLeaderCol/FINENESS,
                    #fine_col=iLeaderCol%FINENESS,
                    #new_angle=Send(self,@GetAngle),
                    #mob_override=TRUE)
               {
                  // Let our leader know so they may stop offering lifts.
                  Send(poLeader,@SendLiftMessage,#who=poLeader,#what=self,#iAction=LIFT_ACCEPT);
                  Send(poLeader,@SetPlayerFlag,#flag=PFLAG2_OFFER_LIFT,#value=FALSE,#flagset=2);

                  propagate;
               }
            }
            else if piStayClose > 2
            {
               piStayClose = 2;
            }
         }

         // First things first: If we have a trigger object, let the leader know
         // that we are ready to activate it, but only if it's fresh.
         oObject = poObject;
         poObject = Send(poOwner,@GetMercenaryTriggerObject,#who=self);

         if (poObject <> $)
            AND (oObject <> poObject)
         {
            Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_object,
               #parm1=Send(poObject,@GetDef),#parm2=Send(poObject,@GetName));
         }

         // Secondly, let's see if we have anything interesting to say about
         // our current info object. Let's see what that is first.
         oInfo = Send(poOwner,@GetMercenaryInfoObject,#who=poLeader);

         // No pointers from the room we're in. Let's look around for enemies.
         if oInfo = $
         {
            oInfo = Send(self,@GetClosestMonster);
         }

         if (oInfo <> $)
         {
            poInfo = oInfo;
            iInfo = FALSE;

            if IsClass(poInfo,&Monster) AND Send(poLeader,@UserDisplayMobQuestActive,#what=poInfo)
            {
               iInfo |= MONSTER_INFO_QUEST;
            }

            Send(self,@GiveInfo,#iInfo=iInfo);
         }

         // Finally, try to be helpful and provide light with a torch if needed.
         Send(self,@FollowerAdjustLight);
      }

      // Finally, maintenance work. Gotta conserve that mana and what not.
      if GetTime() - piOutOfCombatAction > 5
      {
         // Periodically heal up, cure debuffs, remove curses when out of combat.
         if (poTarget = $)
            AND (GetTime() - piCombatCheck > FOLLOWER_OUT_OF_COMBAT_DELAY*100/(100+piIntellect+piMysticism))
         {
            Send(self,@MonsterAction);
         }

         // REs are no longer maintained when out of combat for too long secs.
         // Neither are minions such as Reflections, Evil Twins etc.
         if (GetTime() - piCombatCheck > FOLLOWER_MAINTAIN_TIME)
         {
            foreach i in plRadiusEnchantments
            {
               oEnch = Nth(i,2);
               state = Nth(i,3);
               if (Send(oEnch,@GetCaster,#state=state) = self)
               {
                  Send(oEnch,@BreakTrance,#who=self,#state=state,#event=EVENT_REST);
               }
            }

            Send(self,@RemoveAllMinions);
         }

         piOutOfCombatAction = GetTime();
      }

      propagate;
   }

   GetClosestMonster()
   {
      local iRangeSquared, oTarget, iThisRangeSquared, i, iDistRow, iDistCol, oObject;

      if poOwner = $
      {
         return $;
      }

      iRangeSquared = piVisionDistance * piVisionDistance;

      foreach i in Send(poOwner,@GetHolderActive)
      {
         oObject = First(i);

         // We only care about monsters.
         if (oObject = self) OR (NOT IsClass(oObject,&Monster))
         {
            continue;
         }

         // Looks like we found a monster in this room.
         iDistRow = (piRow * FINENESS + piFine_row)
                     - (Send(oObject,@GetRow) * FINENESS + Send(oObject,@GetFineRow));

         iDistCol = (piCol * FINENESS + piFine_col)
                     - (Send(oObject,@GetCol) * FINENESS + Send(oObject,@GetFineCol));

         iThisRangeSquared = Bound((iDistRow*iDistRow+iDistCol*iDistCol)/FINENESS_SQUARED,0,$);

         // If we can see a quest mob, we don't need to look no further.
         if Send(poLeader,@UserDisplayMobQuestActive,#what=oObject)
            AND Send(poOwner,@LineOfSight,#obj1=self,#obj2=oObject)
            AND iThisRangeSquared <= 4*piVisionDistance * piVisionDistance
         {
            oTarget = oObject;
            break;
         }

         if (iThisRangeSquared <= iRangeSquared)
            AND Send(poOwner,@LineOfSight,#obj1=self,#obj2=oObject)
         {
            iRangeSquared = iThisRangeSquared;
            oTarget = oObject;
         }
      }

      // oTarget = nil if none are in range.
      return oTarget;
   }

   TargetSwitch(what=$)
   {
      if what = $
         OR poOwner = $
      {
         Debug("BAD target we're switching to here!");

         return FALSE;
      }

      // Can't switch targets to the leader.
      if (what = poLeader)
      {
         return FALSE;
      }

      propagate;
   }

   EnterStateEngage( target = $, actnow = TRUE, delay = 0)
   {
      // Can't engage against the leader.
      if (poLeader <> $
         AND poLeader = target)
      {
         Send(self,@EnterStateMove,#actnow=FALSE);

         return;
      }

      if (piState & STATE_MOVE)
      {
         Send(self,@FollowerEnterCombat,#target=target);
      }

      piCombatCheck = GetTime();

      propagate;
   }

   HowCloseToCommander()
   {
      return piStayClose;
   }

   StayCloseToLeader(bMin=FALSE)
   {
      if bMin AND (piStayClose <> 1)
      {
         piStayClose = 1;

         return TRUE;
      }
      else if piStayClose >= 2
      {
         piStayClose /= 2;

         return TRUE;
      }

      return FALSE;
   }

   KeepDistanceFromLeader(bMax=FALSE)
   {
      if bMax AND (piStayClose <> FOLLOWER_MAX_DISTANCE_LEADER)
      {
         piStayClose = FOLLOWER_MAX_DISTANCE_LEADER;

         return TRUE;
      }
      else if piStayClose <= 4
      {
         piStayClose *= 2;

         return TRUE;
      }

      return FALSE;
   }

   MercenaryCommand(what=$,message=$)
   {
      if (what <> poLeader)
      {
         propagate;
      }

      //// Follower Chat Commands
      // Send follower away temporarily
      if StringContain(message,follower_break_trigger)
      {
         Send(self,@FollowerAbsence,#iDelay=3000);
         Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_break);
         Send(self,@FaceLeader);
         Send(self,@DoWave);

         return TRUE;
      }

      // Ask follower to say what spells they know
      if StringContain(message,follower_spells_trigger)
      {
         Post(poLeader,@MsgSendUserCallback,#what=self,#sCallback=SetString($,@FollowerSpellInform));
         Send(self,@FaceLeader);

         return TRUE;
      }

      // Ask follower to come closer
      if StringContain(message,follower_closer_trigger)
      {
         if Send(self,@StayCloseToLeader)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_closer);
            Send(self,@FaceLeader);
            Send(self,@DoPoint);
         }
         else
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_not_closer);
         }

         return TRUE;
      }

      // Ask follower to keep min distance
      if StringContain(message,follower_close_trigger)
      {
         if Send(self,@StayCloseToLeader,#bMin=TRUE)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_close);
            Send(self,@FaceLeader);
            Send(self,@DoPoint);
         }

         return TRUE;
      }

      // Ask follower to move farther away
      if StringContain(message,follower_farther_trigger)
      {
         if Send(self,@KeepDistanceFromLeader)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_farther);
         }
         else
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_not_farther);
         }

         return TRUE;
      }

      // Ask follower to keep max distance
      if StringContain(message,follower_far_trigger)
      {
         if Send(self,@KeepDistanceFromLeader,#bMax=TRUE)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_far);
         }

         return TRUE;
      }

      // Give the follower a friendly greeting!
      if (StringContain(message,follower_hello_trigger_a)
         OR StringContain(message,follower_hello_trigger_b)
         OR StringContain(message,follower_hello_trigger_c)
         OR StringContain(message,follower_hello_trigger_d))
      {
         Post(self,@GreetLeader,#bRequested=TRUE);
         Send(self,@FaceLeader);

         return TRUE;
      }

      // Ask follower for information about the environment.
      if StringContain(message,follower_info_trigger)
      {
         poInfo = poOwner;
         Post(self,@GiveInfo,#bRequested=TRUE);
         Send(self,@FaceLeader);

         return TRUE;
      }

      // Ask follower to brief us on our quests.
      if StringContain(message,follower_brief_trigger)
      {
         Post(self,@BriefLeader,#bRequested=TRUE);
         Send(self,@FaceLeader);

         return TRUE;
      }

      // Ask follower to refresh our memory with some tutorials.
      if StringContain(message,follower_commands_trigger)
      {
         if StringContain(message,follower_commands_advanced_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_commands_advanced);
         }
         else if StringContain(message,follower_commands_social_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_commands_social);
         }
         else if StringContain(message,follower_commands_settings_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_commands_settings);
         }
         else if StringContain(message,follower_commands_say_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_commands_say);
         }
         else
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_commands_basic);
         }
      }

      // Ask follower to refresh our memory with some tutorials.
      if StringContain(message,follower_refresh_trigger)
      {
         if StringContain(message,follower_refresh_health_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razabar_sign);
         }
         else if StringContain(message,follower_refresh_items_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razasmith_sign);
         }
         else if StringContain(message,follower_refresh_news_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razahall_sign);
         }
         else if StringContain(message,follower_refresh_communication_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razahut_sign);
         }
         else if StringContain(message,follower_refresh_basic_controls_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razainn_Sign);
         }
         else if StringContain(message,follower_refresh_offering_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razashop_sign);
         }
         else if StringContain(message,follower_refresh_navigation_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=raza_sign);
         }
         else if StringContain(message,follower_refresh_leaving_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=raza_sign2);
         }
         else if StringContain(message,follower_refresh_fighting_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razacrypt_sign);
         }
         else if StringContain(message,follower_refresh_magic_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razacrypt_sign2);
         }
         else if StringContain(message,follower_refresh_jumping_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razacrypt_sign3);
         }
         else if StringContain(message,follower_refresh_objects_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=razacrypt_sign4);
         }
         else
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_refresh);
         }

         Send(self,@FaceLeader);

         return TRUE;
      }

      // Ask follower to give us some tips.
      if StringContain(message,follower_tips_trigger)
      {
         if StringContain(message,follower_tips_vault_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=BarVault_sign_desc);
         }
         else if StringContain(message,follower_tips_bank_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=tosbank_sign_desc);
         }
         else if StringContain(message,follower_tips_mend_trigger)
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=TosSmithy_sign_desc);
         }
         else
         {
            Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_tips);
         }

         Send(self,@FaceLeader);

         return TRUE;
      }

      // Ask follower what commands he accepts
      if StringContain(message,follower_help_trigger)
      {
         Post(self,@MercenarySayToOne,#target=what,#message_rsc=follower_help);
         Send(self,@FaceLeader);

         return TRUE;
      }

      propagate;
   }

   GiveInfo(bRequested=FALSE,iInfo=FALSE)
   {
      local rIntro, i, rInfo, lInfo, oObject, iTime,cClass;

      rIntro = follower_info_repeat_none;

      // No spamming veterans unless requested!
      if (NOT bRequested) AND Send(poLeader,@IsVeteran)
      {
         return FALSE;
      }

      if poInfo = $
      {
         poInfo = poOwner;
      }

      // Check if we have recently mentioned the info object...
      if plInfo <> $
      {
         if IsClass(poInfo,&Monster)
         {
            cClass = GetClass(poInfo);

            foreach i in plInfo
            {
               if (Nth(i,2) = cClass)
                  AND (Nth(i,3) = iInfo)
               {
                  lInfo = i;
                  break;
               }
            }
         }
         else
         {
            foreach i in plInfo
            {
               if (Nth(i,2) = poInfo)
                  AND (Nth(i,3) = iInfo)
               {
                  lInfo = i;
                  break;
               }
            }
         }

         // Looks like we have. How recently?
         if lInfo <> $
         {
            iTime = Send(poInfo,@GetFollowerInfoTime,#who=poLeader,#iInfo=iInfo);

            // Someone's asking or we got a quest update
            // or it's simply been a while...
            if bRequested
               OR (iTime AND GetTime() - First(lInfo) > iTime)
            {
               plInfo = DelListElem(plInfo,lInfo);
            }
            // No one cares. Let's not be repetitive.
            else
            {
               return FALSE;
            }

            // Since we are repeating ourselves, let's point that out.
            if bRequested
            {
               switch(Random(1,3))
               {
                  case 1:
                     rIntro = follower_info_repeat_a;
                     break;
                  case 2:
                     rIntro = follower_info_repeat_b;
                     break;
                  case 3:
                     rIntro = follower_info_repeat_c;
                     break;
               }
            }
         }
      }

      // We have an object and we'd like to talk about it. What though?
      rInfo = Send(poInfo,@GetFollowerInfo,#who=poLeader,#iInfo=iInfo);

      // Looks like we have nothing to say about that object. Awkward...
      if rInfo = $
      {
         // If we have been asked, we gotta come clean now.
         if bRequested
         {
            rInfo = follower_info_none;
         }
         // Noone asked. Phew! Act like nothing happened.
         // Not sure why we wanted to say anything to begin with really...
         else
         {
            return FALSE;
         }
      }

      // You are not so different, you and the exactly identical creature next to you...
      // It's probably good enough if we inform our leader once per monsterclass.
      if IsClass(poInfo,&Monster)
      {
         poInfo = GetClass(poInfo);
      }

      // Since we're gonna say something on the matter, let's keep track of it.
      plInfo = Cons([GetTime(),poInfo,iInfo],plInfo);

      Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_info,
         #parm1=rIntro,#parm2=rInfo);

      return TRUE;
   }

   ResetInfo(oObject=$,iTime=0)
   {
      local lInfo;

      if oObject <> $
      {
         foreach lInfo in plInfo
         {
            if Nth(lInfo,2) = oObject
            {
               plInfo = DelListElem(plInfo,lInfo);
            }
         }
      }
      else if iTime
      {
         foreach lInfo in plInfo
         {
            if (First(lInfo) - GetTime()) < iTime
            {
               plInfo = DelListElem(plInfo,lInfo);
            }
         }
      }
      else
      {
         foreach lInfo in plInfo
         {
            plInfo = DelListElem(plInfo,lInfo);
         }

         plInfo = $;
      }

      return;
   }

   MercenaryJoinMessage(what=$,bContracted=FALSE)
   {
      if bContracted
      {
         Post(self,@MercenarySayToOne,#target=what,#message_rsc=vrMercenaryJoinContracted);
      }

      return;
   }

   GreetLeader(bRequested=FALSE)
   {
      local lInfo, rGreet, rEnd, iTime;

      rEnd = follower_greet_leader_end_a;

      // Check if we have recently exchanged pleasantries.
      // We simply use our plInfo list and check for our leader.
      if plInfo <> $
      {
         lInfo = GetListNode(plInfo,2,poLeader);

         // Looks like we have. How recently?
         if lInfo <> $
         {
            iTime = GetTime() - First(lInfo);

            // It's been quite some time.
            if iTime > FOLLOWER_HIATUS
            {
               plInfo = DelListElem(plInfo,lInfo);
            }
            // Leader may suffer from Asperger syndrome. Be polite and reply.
            else if bRequested AND iTime > FOLLOWER_LONG_PAUSE
            {
               rEnd = follower_greet_leader_end_b;
               plInfo = DelListElem(plInfo,lInfo);
            }
            // It's getting a bit annoying.
            else if bRequested AND iTime > FOLLOWER_EXTENDED_PAUSE
            {
               rEnd = follower_greet_leader_end_c;
               plInfo = DelListElem(plInfo,lInfo);
            }
            // Yeah, let's ignore this...
            else
            {
               return;
            }
         }
      }

      switch(Random(1,3))
      {
         case 1:
            rGreet = follower_greet_leader_a;
            break;
         case 2:
            rGreet = follower_greet_leader_b;
            break;
         case 3:
            rGreet = follower_greet_leader_c;
            break;
      }

      Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_greet_leader_template,
         #parm1=rGreet,#parm2=Send(poLeader,@GetTrueName),#parm3=rEnd);

      // We said hello. Let's keep track of it.
      plInfo = Cons([GetTime(),poLeader,FALSE],plInfo);

      return;
   }

   BriefLeader(template=$,node=$)
   {
      local lQuests, i, oMonster, oNPC, oCargo, rQuest, iCount;

      // This only happens when we request a briefing.
      if (template = $ OR node = $)
      {
         lQuests = Send(poLeader,@GetActiveQuests);

         if lQuests = $
         {
            Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_brief_leader_requested_none);
         }
         else
         {
            Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=Send(self,@GetRequestedBriefingStarter));

            iCount = 0;

            foreach i in lQuests
            {
               template = First(i);
               node = Nth(i,2);

               // Get the involved parties first.
               oMonster = Send(node,@GetQuestMonster);
               oNPC = Send(node,@GetDestNPC);
               oCargo = Send(node,@GetCargo);

               // Monster kills don't really involve anything else.
               if oMonster <> $
               {
                  Send(poLeader,@MsgSendUser,
                     #message_rsc=follower_brief_leader_requested_template,
                     #parm1=follower_brief_leader_requested_kill,
                     #parm2=Send(oMonster,@GetIndef),#parm3=Send(oMonster,@GetName),
                     #parm4=follower_brief_leader_requested_period);
               }

               // Let's see if we have to obtain some cargo.
               else if IsObject(oCargo)
                  AND ((Send(oCargo,@GetOwner) <> poLeader)
                     AND NOT (IsClass(oCargo,&NumberItem)
                        AND Send(poLeader,@CountHoldingHowMany,#class=GetClass(oCargo)) >= Send(oCargo,@GetNumber)))
               {
                  Send(poLeader,@MsgSendUser,
                     #message_rsc=follower_brief_leader_requested_template,
                     #parm1=follower_brief_leader_requested_obtain,
                     #parm2=Send(oCargo,@GetIndef),#parm3=Send(oCargo,@GetName),
                     #parm4=follower_brief_leader_requested_period);
               }

               // We have to visit an NPC - usually to deliver cargo, be it an item or word.
               else if oNPC <> $
               {
                  if oCargo <> $
                  {
                     // We have physical cargo with us. This looks like a delivery.
                     if IsObject(oCargo)
                        AND ((Send(oCargo,@GetOwner) = poLeader)
                           OR (IsClass(oCargo,&NumberItem)
                              AND Send(poLeader,@CountHoldingHowMany,#class=GetClass(oCargo)) >= Send(oCargo,@GetNumber)))
                     {
                        Send(poLeader,@MsgSendUser,
                           #message_rsc=follower_brief_leader_requested_template_combined,
                           #parm1=follower_brief_leader_requested_visit,
                           #parm2=Send(oNPC,@GetIndef),#parm3=Send(oNPC,@GetName),
                           #parm4=follower_brief_leader_requested_deliver,
                           #parm5=Send(oCargo,@GetDef),#parm6=Send(oCargo,@GetName),
                           #parm7=follower_brief_leader_requested_period);
                     }
                     // Sounds like we are delivering a message.
                     else if IsString(oCargo)
                     {
                        Send(poLeader,@MsgSendUser,
                           #message_rsc=follower_brief_leader_requested_say_template_string,
                           #parm1=follower_brief_leader_requested_visit,
                           #parm2=Send(oNPC,@GetIndef),#parm3=Send(oNPC,@GetName),
                           #parm4=follower_brief_leader_requested_say,
                           #parm5=oCargo,
                           #parm7=follower_brief_leader_requested_say_period);
                     }
                     else
                     {
                        Send(poLeader,@MsgSendUser,
                           #message_rsc=follower_brief_leader_requested_say_template_resource,
                           #parm1=follower_brief_leader_requested_visit,
                           #parm2=Send(oNPC,@GetIndef),#parm3=Send(oNPC,@GetName),
                           #parm4=follower_brief_leader_requested_say,
                           #parm5=oCargo,
                           #parm7=follower_brief_leader_requested_say_period);
                     }
                  }
                  // Nope, just a visit.
                  else
                  {
                     Send(poLeader,@MsgSendUser,
                        #message_rsc=follower_brief_leader_requested_template,
                        #parm1=follower_brief_leader_requested_visit,
                        #parm2=Send(oNPC,@GetIndef),#parm3=Send(oNPC,@GetName),
                        #parm4=follower_brief_leader_requested_period);
                  }
               }

               ++iCount;
            }

            iCount = Bound(iCount,1,5);

            Send(self,@MercenarySayToOne,#target=poLeader,
               #message_rsc=Send(self,@GetRequestedBriefingEnd,#iCount=iCount));
         }

         return;
      }

      // It hasn't been requested, but maybe we have something interesting to say.
      switch(Send(node,@GetQuestNodeTemplateIndex))
      {
         case QNT_ID_RAZA_MUMMY_TWO:
            rQuest = follower_quest_mummy;
            break;
      }

      if rQuest <> $
      {
         Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=rQuest);

         return;
      }

      // We don't have anything prepared, but we can at least try to sum up the next step.
      oMonster = Send(node,@GetQuestMonster);
      if oMonster <> $
      {
         Send(poLeader,@MsgSendUser,
            #message_rsc=follower_brief_leader_template,
            #parm1=Send(self,@GetBriefingStarter),
            #parm2=Send(self,@GetBriefingWe),
            #parm3=follower_brief_leader_monster_start,
            #parm4=Send(oMonster,@GetIndef),#parm5=Send(oMonster,@GetName),
            #parm6=Send(self,@GetBriefingEnd));

         return;
      }

      // Nope, but maybe we have to get something?
      oCargo = Send(node,@GetCargo);
      if (oCargo <> $) 
         AND IsObject(oCargo) 
         AND ((Send(oCargo,@GetOwner) <> poLeader)
            AND NOT (IsClass(oCargo,&NumberItem)
               AND Send(poLeader,@CountHoldingHowMany,#class=GetClass(oCargo)) >= Send(oCargo,@GetNumber)))
      {
         Send(poLeader,@MsgSendUser,
            #message_rsc=follower_brief_leader_template,
            #parm1=Send(self,@GetBriefingStarter),
            #parm2=Send(self,@GetBriefingWe),
            #parm3=follower_brief_leader_cargo_start,
            #parm4=Send(oCargo,@GetIndef),#parm5=Send(oCargo,@GetName),
            #parm6=Send(self,@GetBriefingEnd));

         return;
      }

      // Well, maybe we just have to say 'hi' to someone.
      oNPC = Send(node,@GetDestNPC);
      if (oNPC <> $) AND (oNPC <> Send(node,@GetSourceNPC))
      {
         Send(poLeader,@MsgSendUser,
            #message_rsc=follower_brief_leader_template,
            #parm1=Send(self,@GetBriefingStarter),
            #parm2=Send(self,@GetBriefingWe),
            #parm3=follower_brief_leader_npc_start,
            #parm4=Send(oNPC,@GetIndef),#parm5=Send(oNPC,@GetName),
            #parm6=Send(self,@GetBriefingEnd));
      }

      return;
   }

   GetRequestedBriefingStarter()
   {
      local rStarter;

      switch(Random(1,5))
