////////////////////////////////////////////////////////////////////////////////
Follower is Human

constants:

   include blakston.khd
   include protocol.khd

   // Follower chat lockout time in ms.
   FOLLOWER_CHAT_DELAY = 6000

   // Distance in regular units.
   FOLLOWER_MAX_DISTANCE_LEADER = 8

   // Chance of 1 in n+1
   FOLLOWER_KILLED_SOMETHING_CHAT_CHANCE = 2
   FOLLOWER_LEADER_KILLED_SOMETHING_CHAT_CHANCE = 3
   FOLLOWER_ENTER_CONTINUOUS_COMBAT_CHANCE = 20
   FOLLOWER_ENTER_BRIEF_PAUSE_CHANCE = 15
   FOLLOWER_ENTER_EXTENDED_PAUSE_CHANCE = 10
   FOLLOWER_ENTER_LONG_PAUSE_CHANCE = 4
   FOLLOWER_ENTER_INACTIVITY_CHANCE = 2
   FOLLOWER_ENTER_RANDOM_CHANCE = 40

   // Number of seconds that define a timespan.
   FOLLOWER_CONTINUOUS_COMBAT = 5
   FOLLOWER_BRIEF_PAUSE = 15
   FOLLOWER_EXTENDED_PAUSE = 60
   FOLLOWER_LONG_PAUSE = 600
   FOLLOWER_MAJOR_PAUSE = 1800
   FOLLOWER_HIATUS = 5400

   // Duration REs are maintained out of combat in seconds.
   FOLLOWER_MAINTAIN_TIME = 30

   // Maximum delay between out of combat actions.
   FOLLOWER_OUT_OF_COMBAT_DELAY = 10

   FOLLOWER_MAX_LEVEL = 150

   FOLLOWER_FRESH = 30
   FOLLOWER_NOVICE = 50
   FOLLOWER_EXPERIENCED = 70
   FOLLOWER_SEASONED = 90
   FOLLOWER_HARDENED = 110
   FOLLOWER_VETERAN = 130
   FOLLOWER_MASTER = 150

   // Effect chance of viLevel*chance/base.
   FOLLOWER_EFFECT_BASE = 150
   FOLLOWER_EFFECT_CHANCE_LOW = 20
   FOLLOWER_EFFECT_CHANCE_FAIR = 40
   FOLLOWER_EFFECT_CHANCE_GOOD = 60
   FOLLOWER_EFFECT_CHANCE_HIGH = 80
   FOLLOWER_EFFECT_CHANCE_TRUE = 100

   FOLLOWER_SPECIALIZED_MANA_PERCENTAGE = 50
   FOLLOWER_SPECIALIZED_EXERTION_PERCENTAGE = 50
   FOLLOWER_SPECIALIZED_FREQUENCY_PERCENTAGE = 200
   FOLLOWER_SPECIALIZED_POWER_PERCENTAGE = 200


resources:

   include follower.lkod

   follower_name_rsc = "follower"
   follower_dead_name_rsc = "unconscious follower"
   follower_desc_rsc = \
      "A trustworthy soul that has decided to join you on your adventures."

   // Mercenary message adjusted specifically for followers
   // Triggered upon firing a follower
   follower_leave = \
      "Alright, friend.  Don't worry, I'm sure I can make it on my own from "
      "here on and perhaps, we will meet again one day.  I'll just drop the "
      "loot that you shared with me on the floor - be sure to pick it up!  "
      "Anyway... thanks for the great run and stay safe out there!"

   // Originally automatically displayed on first login.
   // Not integrated into follower chat.
   follower_commands_basic = \
      "The following commands may be entered directly into chat input.  "
      "Most of them can be abbreviated: '~I~Bs~I~B' for '~Isay~I', "
      "'~I~Bb~I~B' for '~Ibroadcast~I'...\n"
      "~Bsay~B (message)   ~Isend a message to everyone in the same room~I\n"
      "~Btell~B (player name) (message)   ~Isend a direct message to a single player~I\n"
      "~Byell~B (message)   ~Isend a message that can be heard in adjacent rooms~I\n"
      "~Bbroadcast~B (message)   ~Isend a message to everyone that is logged on~I\n\n"
      "~Bcast~B (spellname)   ~Icast the spell you specified~I\n"
      "~Bperform~B (skillname)   ~Iperform the skill you specified (active skills only)~I\n"
      "~Brest/stand~B   ~Irest to recover resources more quickly, stand to stop resting~I\n\n"
      "~Bget~B   ~Ibring up a list of items in reach and view that you can get from the ground~I\n"
      "~Bdrop~B   ~Ibring up a list of items in your inventory that you can drop~I\n"
      "~Bbuy~B   ~Iopen up the buy window near a vendor~I\n"
      "~Boffer~B   ~Iselect inventory items to offer to a nearby vendor or player~I\n\n"
      "~Bwho~B   ~Ishow a list of all the people logged into the game right now~I\n"
      "~Bmail~B   ~Iopen up your mail folder~I\n"
      "~Bhelp~B   ~Iopen the game's web-based help pages~I\n"
      "~Bquit~B   ~Iquit to character selection~I\n\n"
      "~IIf you want to know about other commands, enter ~B's commands advanced'~B, "
      "~B's commands social'~B, ~B's commands settings'~B or ~B's commands say'~B!"

   follower_commands_advanced = \
      "These are advanced game commands that you may find helpful a bit later...\n"
      "~Bdeposit~B (amount)   ~Ideposit the amount of shillings near a banker~I\n"
      "~Bwithdraw~B (amount)   ~Iwithdraw the amount of shillings near a banker~I\n"
      "~Bbalance~B   ~Idisplay your current account balance near a banker~I\n\n"
      "~Buse~B   ~Iactivate nearby object or bring up contents of a nearby container~I\n"
      "~Bput~B   ~Iselect inventory items to be put into a nearby container~I\n\n"
      "~Balias~B   ~Ibring up a window to organize your F-Keys as hotkeys~I\n"
      "~Bcmdalias~B   ~Ibring up a window to organize command aliases~I\n\n"
      "~Bmap~B   ~Itoggle the display of a large zone map in the main window ~I\n\n"
      "~Btime~B   ~Iprint the current game time ~I\n\n"
      "~Bappeal~B (message)  ~Isend a message to every guide/admin that is logged on ~I\n\n"
      "~Bsuicide~B   ~Ibring up a prompt that allows you to delete your character~I"

   follower_commands_social = \
      "These are commands that you can use to better communicate with your friends...\n"
      "~Bemote~B (message)   ~Iallows you to tell those nearby what you are doing~I\n"
      "~Bpoint/wave/dance~B   ~Iexecute a visual emote~I\n"
      "~Bneutral/happy/sad/wry~B   ~Iset your facial expression accordingly~I\n\n"
      "~Bgroup~B   ~Ibring up a window that allows you to manage messaging groups~I\n"
      "~Bnewgroup~B (groupname)   ~Icreate a new group you can add players to~I\n"
      "~Bdelgroup~B (groupname)   ~Idelete the specified group~I\n"
      "~Baddgroup~B (groupname) (playername)   ~Iadd a player to the existing group~I\n"
      "~Bt~B (groupname) (message)   ~Isend a message to every player in that group~I\n\n"
      "~Bguild~B   ~Ibring up the guild window~I\n"
      "~Binvite~B (playername)   ~Iplace a guild invitiation in a nearby player's inventory~I\n"
      "~Btguild~B (message)   ~Isend a message to every logged on guild member~I\n"
      "~Btg set motd~B (message)   ~Iset a message of the day for your guild, printed upon login~I\n"
      "~Btg clear motd~B (message)   ~Iclear your guild's current MotD~I"

   follower_commands_settings = \
      "These are game commands to toggle different game settings...\n"
      "~Bsafety on/off~B   ~Itoggle ability to attack friendly players and soldiers~I\n"
      "~Btempsafe on/off~B   ~Itoggle activation of temporary PvP protection upon a PvP death~I\n\n"
      "~Bspellpower on/off~B   ~Itoggle the display of effective spellpower when casting~I\n\n"
      "~Bgrouping on/off~B   ~Itoggle automatic joining of local players to share combat XP~I\n"
      "~Bautoloot on/off~B   ~Itoggle automatic looting of money and stackable items~I\n\n"
      "~Bautocombine on/off~B   ~Itoggle automatic charge fusing for potions, scrolls and wands~I\n"
      "~Breagentbag on/off~B   ~Itoggle automatic storage of picked up ragents if you own one~I"

   follower_commands_say = \
      "The following commands are said, meaning that they begin with ~B~I's ...'~I~B\n"
      "~Bs inventory sort help~B   ~Iprint information about automatic inventory sorting~I\n"
      "~Bs inventory sort add~B   ~Iadd the next item/itemclass to your ordered list~I\n"
      "~Bs inventory sort clear~B   ~Iclear your current sorting preferences~I\n"
      "~Bs inventory sort report~B   ~Iprint your current sorting preferences~I\n"
      "~Bs sort inventory~B   ~Iautomatically sort your inventory based on your preferences~I\n\n"
      "~Bs start solo survival~B   ~Istart a private survival arena session from a safe place~I\n"
      "~Bs start public survival~B   ~Istart a public survival arena that others can join~I\n"
      "~Bs join public survival~B   ~Ijoin a public survival arena that has just begun~I\n"
      "~Bs start guild survival~B   ~Istart a closed survival arena that only guild members can join~I\n"
      "~Bs join guild survival~B   ~Ijoin your guild's survival arena that has just begun~I"

   // Messages triggered by the follower's return after dying or being left behind.
   follower_return_death = \
      "Whoa!  What happened?  For a moment, everything went black there..."
   follower_return_lost = \
      "Sorry about that.  I must have gotten lost somewhere along the way...  "
      "Good thing I knew that you were going to come here sooner or later!"

   // Message triggered by FollowerDing()
   follower_learn = \
      "Nice! I think I've finally figured out how to cast this new ~I~B%s~I~B spell "
      "I've been trying to learn. I think it might come in handy..."

   // Message triggered by follower acquiring a new trigger object
   follower_object = "Ready to activate %s%s whenever you are!"

   // Messages triggered by QuestFinished()
   follower_quest_finished_a = "Well, that wasn't too bad...  I'm kidding.  That was awful."
   follower_quest_finished_b = "Finally..."
   follower_quest_finished_c = "I guess that wasn't too hard."
   follower_quest_finished_d = "We should do that more often!"
   follower_quest_finished_e = "What'd we get?  Anything good?"
   follower_quest_finished_f = "Well, I sure hope that was worth it!"
   follower_quest_finished_g = "That was some good fun!  Totally no irony there!  I swear!"
   follower_quest_finished_h = "Done!  We ~Iare~I done, right? "
   follower_quest_finished_i = "There we go..."
   follower_quest_finished_j = "What's up with all the running around?  That's such poor quest design..."
   follower_quest_finished_k = "Looks like we're done here..."
   follower_quest_finished_l = "I think we've earned ourselves a drink or two... Your treat."

   // Messages triggered by KilledSomething()
   follower_killed_something_a = "And yet another foe has met it's timely end..."
   follower_killed_something_b = "Are they even trying?!"
   follower_killed_something_c = "That one had it coming!"
   follower_killed_something_d = "My %s really loved that last one..."
   follower_killed_something_e = "Won't they ever learn?"
   follower_killed_something_f = "Ahh... I don't believe my %s and I shall ever tire of this!"

   // Messages triggered by LeaderKilledSomething()
   follower_leader_killed_something_a = "Ohh!  Nice one, friend!"
   follower_leader_killed_something_b = "You really make it look easy..."
   follower_leader_killed_something_c = "Leave me some, will ya?"
   follower_leader_killed_something_d = "By Kraanan, you and your %s really are a match made in heaven!"
   follower_leader_killed_something_e = "Hah!  That was fun to watch!"
   follower_leader_killed_something_f = "Ouch!!  Did you see what your %s did to that poor bastard?!"

   // Messages triggered by FollowerRetreat()
   follower_retreat_a = "Time to fall back a bit!"
   follower_retreat_b = "Orderly retreat!"
   follower_retreat_c = "I'm right with you!"
   follower_retreat_d = "Ouch! This %s really hurts!"

   // Messages triggered by FollowerInjured()
   follower_injured_a = "Hrngh!  I don't think... I'll make it..."
   follower_injured_b = "Augh!  I'm afraid I'm injured pretty badly!"
   follower_injured_c = "Could use some healing, friend."
   follower_injured_d = "Need a bit of help over here!"

   // Messages triggered by FollowerRecovered()
   follower_recovered_a = "Ohh the pain... For a moment there, I thought I was a goner."
   follower_recovered_b = "Phew...  Feeling a bit better again!"
   follower_recovered_c = "Ahh, that's much better."
   follower_recovered_d = "I think I'm all better again!"

   //// Messages triggered by FollowerEnteredCombat()
   // 5 seconds mark
   follower_entered_combat_a_a = "It never ends, does it?"
   follower_entered_combat_a_b = "Is there no end to them?"
   follower_entered_combat_a_c = "Where are they all coming from?!"
   follower_entered_combat_a_d = "If they keep coming, we'll just keep smacking them down..."
   follower_entered_combat_a_e = "You'd think they'd run out of reinforcements at some point."
   follower_entered_combat_a_f = "Keep 'em coming!"
   // 15 seconds mark
   follower_entered_combat_b_a = "Looks like they're coming for more..."
   follower_entered_combat_b_b = "Back into the thick of battle!"
   follower_entered_combat_b_c = "I guess they haven't had enough yet..."
   // 60 seconds mark
   follower_entered_combat_c_a = "That was a nice rest...  Back to breaking some bones!"
   follower_entered_combat_c_b = "Time for some more slaughter!"
   follower_entered_combat_c_c = "Hah!  ...and there I thought we were about to have some peace and quiet."
   // 10 minutes mark
   follower_entered_combat_d_a = "It's about time we got back to business!"
   follower_entered_combat_d_b = "Finally!  I'm not one for waiting around..."
   follower_entered_combat_d_c = "Ahh...  I was starting to worry that we were done for the day."
   // > 10 minutes mark
   follower_entered_combat_e_a = "Hah!  At long last, we get to taste battle again!"
   follower_entered_combat_e_b = \
      "Oh boy!  I can't wait to bash some skulls in!  It feels like it's been forever..."
   follower_entered_combat_e_c = \
      "BATTLE!  I hope I haven't forgotten how to deliver a good beating after all this time..."
   follower_entered_combat_e_d = \
      "Foes ahead!  After all this time! ...brings a tear to my eye.  Really does!"
   follower_entered_combat_e_e = "I can't believe it!  An actual battle!"
   follower_entered_combat_e_f = "Enemies! Wait! Does that mean I finally get to actually do something?"
   follower_entered_combat_e_g = \
      "AMBUSH!  I'm not entirely clear on whether we're the ambushers or the ambushees, but I just love "
      "yelling it..."
   // Generic battle cries that pop up instead of 5, 15 and 60 seconds quotes.
   follower_entered_combat_f_a = "Ahh!  The glory of battle!"
   follower_entered_combat_f_b = "Into the frey!"
   follower_entered_combat_f_c = "For Kraanan!"
   follower_entered_combat_f_d = "For glory!"
   follower_entered_combat_f_e = "I'll cut them down where they stand!"
   follower_entered_combat_f_f = "Hah! There is no escaping my wrath!"
   follower_entered_combat_f_g = "Come at me, foes!"
   follower_entered_combat_f_h = "Into battle!"
   follower_entered_combat_f_i = "There is glory to be won!"
   follower_entered_combat_f_j = "Today's a good day to die!  Just not mine..."

   // Messages triggered by MercenaryCommand()
   follower_break = "Alright. See you later, friend!"
   follower_close = "Very well. I'll stick really close."
   follower_closer = "Very well. I'll follow a bit more closely."
   follower_not_closer = "No offense, but I'm fairly sure I don't want to get ~Ithat~I close."
   follower_far = "Fine, I'll stay far back..."
   follower_farther = "Fine, staying a bit farther back..."
   follower_not_farther = "Are you trying to ditch me?!"
   follower_help = \
      "Need help with something? You can ask me to...\n"
      "...tell you about the basic game ~I~Bcommands~I~B that you can enter in the chat.\n"
      "...give you some ~I~Binfo~I~Brmation about this general area.\n"
      "...~I~Brefresh~I~B your memory about basic game concepts (info signs you may have missed).\n"
      "...give you some ~I~Btips~I~B to make adventuring life easier.\n"
      "...~I~Bbrief~I~B you on quests that we are currently trying to complete.\n"
      "...tell you what ~I~Bspells~I~B I have learned so far.\n"
      "...move in a little ~I~Bcloser~I~B, or really ~I~Bclose~I~B so I don't fall behind.\n"
      "...stay a bit ~I~Bfarther~I~B back or stay ~I~Bfar~I~B back to stay out of trouble.\n"
      "...~I~Bmeet up~I~B with you later in case you don't need me at the moment.\n"
      "You could also tell me that ~I~Bit's time to part ways again~I~B.\n"
      "I'd think twice about that if I were you though.  I bet you'd never "
      "find good company like me again!"
   follower_refresh = \
      "Need me to ~I~Brefresh~I~B your memory a bit?  I can tell you about...\n"
      "...using basic ~I~Bcontrols~I~B.\n"
      "...~I~Bnavigating~I~B the world.\n"
      "...~I~Bcommunicating~I~B with others.\n"
      "...using ~I~Bitems~I~B in your inventory.\n"
      "...~I~Boffering~I~B and selling items to vendors.\n"
      "...~I~Bhealth~I~B, mana, vigor and XP.\n"
      "...using ~I~Bmagic~I~B and items.\n"
      "...~I~Bfighting~I~B monsters.\n"
      "...~I~Bjumping~I~B across gaps.\n"
      "...interacting with ~I~Bobjects~I~B.\n"
      "...using ~I~BNews Globes~I~B to keep in touch with other players.\n"
      "...~I~Bleaving~I~B Raza.\n"
      "~I[Simply say 'refresh topicname' to learn about a topic.]~I"
   follower_tips = \
      "Need some ~I~Btips~I~B?  I can tell you about...\n"
      "...storing items in a ~I~Bvault~I~B.\n"
      "...keeping your shillings safe in a ~I~Bbank~I~B.\n"
      "...~I~Bmending~I~B items in need of repair.\n"
      "~I[Simply say 'tips topicname' to learn about a topic.]~I"

   // Messages used by FollowerSpellInform() triggered by MercenaryCommand()
   follower_no_spell_inform = "So far, I haven't learned any spells"
   follower_one_spell_inform = "So far, I've learned the spell "
   follower_spell_inform = "So far, I've learned the spells "
   follower_and = " and "
   follower_comma = ", "
   follower_spell = "~I~B%s~I~B"
   follower_say_start = "~MYour follower tells you, \""
   follower_say_end = ".~n~M\""

   // Messaged used by GiveInfo() triggered by MercenaryCommand()
   follower_info = "%s%s"
   follower_info_repeat_none = ""
   follower_info_repeat_a = "Well, as I've said before... "
   follower_info_repeat_b = "I believe I'm repeating myself, but... "
   follower_info_repeat_c = "Again... "
   follower_info_none = \
      "I'm afraid I don't have any useful information about this place.  Sorry!"

   // Messaged used by GreetLeader() triggered by MercenaryCommand()
   follower_greet_leader_template = "%s%s%s"
   follower_greet_leader_a = "Hey there, "
   follower_greet_leader_b = "Good to see you, "
   follower_greet_leader_c = "Hello, "
   follower_greet_leader_end_a = "!"
   follower_greet_leader_end_b = "."
   follower_greet_leader_end_c = "..."

   // Messaged used by BriefLeader() triggered by MercenaryCommand()
   follower_brief_leader_requested_none = \
      "I double checked my notes, but it looks like we have... nothing to do?  That can't be right!  "
      "Let's go out there and find something to do!"
   follower_brief_leader_requested_template = "%s%s%s%s"
   follower_brief_leader_requested_template_combined = "%s%s%s%s%s%s%s"
   follower_brief_leader_requested_start_a = "Let me check my notes.  I believe we have to..."
   follower_brief_leader_requested_start_b = "According to my notes, we ought to..."
   follower_brief_leader_requested_start_c = "If I remember correctly, we were supposed to..."
   follower_brief_leader_requested_start_d = "From what I remember, we are expected to..."
   follower_brief_leader_requested_start_e = "Where's my travel log?  Ah, there we go!  We need to..."
   follower_brief_leader_requested_kill = "~MThe follower tells you, \"...kill "
   follower_brief_leader_requested_visit = "~MThe follower tells you, \"...visit "
   follower_brief_leader_requested_obtain = "~MThe follower tells you, \"... obtain "
   follower_brief_leader_requested_deliver = " and deliver "
   follower_brief_leader_requested_period = ".~n~M\""
   follower_brief_leader_requested_end_a = "That's it. Nothing else."
   follower_brief_leader_requested_end_b = "That seems to be all."
   follower_brief_leader_requested_end_c = "Apart from that... nothing."
   follower_brief_leader_requested_end_d = "That should be all."
   follower_brief_leader_requested_end_e = "I hope I didn't miss anything."
   follower_brief_leader_requested_end_f = "That's quite the list there!  We'd better get going!"
   follower_brief_leader_requested_end_g = "Geez...  We'll need a vacation after that!"

   follower_brief_leader_requested_say_template_string = "%s%s%s%s%q%s"
   follower_brief_leader_requested_say_template_resource = "%s%s%s%s%s%s"
   follower_brief_leader_requested_say = " and say '"
   follower_brief_leader_requested_say_period = "'.~n~M\""

   follower_brief_leader_template = "%s%s%s%s%s%s"
   follower_brief_leader_start_a = "~MThe follower tells you, \"Alright, quick recap - "
   follower_brief_leader_start_b = "~MThe follower tells you, \"If I got that right "
   follower_brief_leader_start_c = "~MThe follower tells you, \"Sounds as if "
   follower_brief_leader_start_d = "~MThe follower tells you, \"Looks like "
   follower_brief_leader_start_e = "~MThe follower tells you, \"I guess "
   follower_brief_leader_start_f = "~MThe follower tells you, \"Hmm... so "
   follower_brief_leader_start_g = "~MThe follower tells you, \"I believe "
   follower_brief_leader_we_a = "we "
   follower_brief_leader_we_b = "you and I "
   follower_brief_leader_we_c = "the two of us "
   follower_brief_leader_we_d = "the local heroes "
   follower_brief_leader_monster_start = "have to kill "
   follower_brief_leader_npc_start = "should visit "
   follower_brief_leader_cargo_start = "have to get "
   follower_brief_leader_end_a = ".  Sounds easy enough.~n~M\""
   follower_brief_leader_end_b = ".  Let's get going then.~n~M\""
   follower_brief_leader_end_c = ".  Alright.  Let's do it.~n~M\""
   follower_brief_leader_end_d = ".  Sounds like fun...~n~M\""
   follower_brief_leader_end_e = ".  What could possibly go wrong?~n~M\""

   // Triggers for MercenaryCommand()
   follower_commands_trigger = "command"
   follower_commands_advanced_trigger = "adv"
   follower_commands_social_trigger = "soc"
   follower_commands_settings_trigger = "set"
   follower_commands_say_trigger = "say"
   follower_spells_trigger = "spells"
   follower_break_trigger = "meet up"
   follower_close_trigger = "close"
   follower_closer_trigger = "closer"
   follower_far_trigger = "far"
   follower_farther_trigger = "farther"
   follower_help_trigger = "help"
   follower_info_trigger = "info"
   follower_brief_trigger = "brief"
   follower_refresh_trigger = "refresh"
   follower_refresh_health_trigger = "he"
   follower_refresh_items_trigger = "it"
   follower_refresh_news_trigger = "ne"
   follower_refresh_communication_trigger = "com"
   follower_refresh_basic_controls_trigger = "con"
   follower_refresh_offering_trigger = "of"
   follower_refresh_navigation_trigger = "na"
   follower_refresh_leaving_trigger = "le"
   follower_refresh_fighting_trigger = "fi"
   follower_refresh_magic_trigger = "ma"
   follower_refresh_jumping_trigger = "ju"
   follower_refresh_objects_trigger = "ob"
   follower_tips_trigger = "tip"
   follower_tips_bank_trigger = "ba"
   follower_tips_vault_trigger = "va"
   follower_tips_mend_trigger = "me"

   follower_hello_trigger_a = "hi"
   follower_hello_trigger_b = "hey"
   follower_hello_trigger_c = "hello"
   follower_hello_trigger_d = "hail"

   follower_pvp = "Ayeeeeeeeeeeeeeeeeeeeeeeeeeeehhhhhhhhhhhhhhhhh!!! ~IGlbs.~I"

   // The loooong list of quest feedback. At least at some point, hopefully?
   follower_quest_mummy = \
      "Back to the mausoleum, kill the shadow mummy.  Got it.  I believe the elder "
      "also mentioned something about levers that needed to be flipped.  Sounds "
      "complicated, but I guess we'll deal with that once we get there.  Let's "
      "get going!"

classvars:

   vrDesc = follower_desc_rsc

   viSpeed = SPEED_VERY_FAST
   viAttributes = MOB_LISTEN | MOB_RECEIVE
   vrMercenaryLeave = follower_leave
   vrFollowerReturnDeath = follower_return_death
   vrFollowerReturnLost = follower_return_lost
   viSocial = 100
   vrInfo = $
   viInfo_time = 1800
   viChat_frequency = 100

properties:

   vrName = follower_name_rsc
   vrDead_name = follower_dead_name_rsc
   vrSound_aware = $
   viChanceFemale = 50
   viKarma = 0
   viLevel = 250
   viDifficulty = 1
   piRole = 0
   ptAbsence = $
   poBody = $
   piOutOfCombatAction = 0
   piCombatCheck = 0
   viNaturalVigorRegeneration = 0
   piStayClose = 2
   ptChat = $
   pbDontDispose = TRUE
   poInfo = $
   plInfo = $

   viAttacks = ATTACK_SLASH
   viBonusSwing = 0
   viPoisonChance = 0
   viBleedChance = 0
   viSiphonChance = 0
   viFatigueChance = 0
   viBurnChance = 0

messages:

   Constructor(iLevel=0,iDifficulty=$,iGender=$,iRole=0)
   {
      piRole = iRole;

      if iLevel > 0
      {
         viLevel = iLevel;
      }

      if iDifficulty <> $
      {
         viDifficulty = iDifficulty;
      }

      if iGender <> $
      {
         if iGender = GENDER_MALE
         {
            viChanceFemale = 0;
         }
         else
         {
            viChanceFemale = 100;
         }
      }

      propagate;
   }

   // Followers aren't randomized but come with certain stat distributions based on their role.
   CreateStats()
   {
      switch (piRole)
      {
         case FOLLOWER_ROLE_WARRIOR:
            piAgility = 40;
            piAim = 40;
            piMight = 50;
            piStamina = 50;
            piIntellect = 10;
            piMysticism = 10;
            break;

         case FOLLOWER_ROLE_WIZARD:
            piAgility = 25;
            piAim = 25;
            piMight = 25;
            piStamina = 25;
            piIntellect = 50;
            piMysticism = 50;
            break;

         case FOLLOWER_ROLE_PRIEST:
            piAgility = 20;
            piAim = 20;
            piMight = 30;
            piStamina = 40;
            piIntellect = 40;
            piMysticism = 50;
            break;

         case FOLLOWER_ROLE_WARLOCK:
            piAgility = 50;
            piAim = 30;
            piMight = 15;
            piStamina = 20;
            piIntellect = 50;
            piMysticism = 35;
            break;

         default:
            piAgility = 35;
            piAim = 35;
            piMight = 35;
            piStamina = 35;
            piIntellect = 30;
            piMysticism = 35;
            break;
      }

      return;
   }

   Delete(bConfirm=FALSE)
   {
      // No accidential deletions. Go into absence unless
      // we have a confirmed deletion or are without leader.
      if NOT (bConfirm OR (poLeader = $))
      {
         Send(self,@FollowerAbsence);

         return;
      }

      if ptAbsence <> $
      {
         DeleteTimer(ptAbsence);
         ptAbsence = $;
      }

      // If the follower had any minions, remove them.
      Send(self,@RemoveAllMinions);

      propagate;
   }

   SetEquipment()
   {
      local oItem, iRandom, iColor, iAdjustment;

      //// Gear
      // Armor
      if       viLevel <= 35 {oItem = Create(&LeatherArmor);}
      else if  viLevel <= 55 {oItem = Create(&ChainArmor);}
      else if  viLevel <= 75 {oItem = Create(&ScaleArmor);}
      else if  viLevel <= 95 {oItem = Create(&PlateArmor);}
      else                   {oItem = Create(&NeruditeArmor);}
      Send(self,@AddEquipmentObject,#what=oItem);

      // Weapon
      if       viLevel <= 35 {oItem = Create(&Mace);}
      else if  viLevel <= 45 {oItem = Create(&ShortSword);}
      else if  viLevel <= 55 {oItem = Create(&Hammer);}
      else if  viLevel <= 65 {oItem = Create(&LongSword);}
      else if  viLevel <= 75 {oItem = Create(&Axe);}
      else if  viLevel <= 85 {oItem = Create(&Scimitar);}
      else if  viLevel <= 95 {oItem = Create(&MysticSword);}
      else                   {oItem = Create(&NeruditeSword);}
      Send(self,@AddEquipmentObject,#what=oItem);

      // Shield
      if       viLevel <= 35 {oItem = Create(&WoodenShield);}
      else if  viLevel <= 55 {oItem = Create(&MetalShield);}
      else if  viLevel <= 75 {oItem = Create(&GoldShield);}
      else                   {oItem = Create(&KnightShield);}
      Send(self,@AddEquipmentObject,#what=oItem);

      // Gauntlets
      if viLevel >= 60
      {
         oItem = Create(&Gauntlet);
         Send(self,@AddEquipmentObject,#what=oItem);
      }

      // Helmet
      if viLevel >= 80
      {
         oItem = Create(&SimpleHelm);
         Send(self,@AddEquipmentObject,#what=oItem);
      }

      //// Clothes
      // Pants/Skirt
      iRandom = Random(1,100);
      iColor = Send(SYS,@GetRandomGreyTranslation);
      // Male mercs lack self confidence and are rarely seen in skirts.
      if       viGender = 2   {iRandom += 50;}

      if       iRandom <= 75  {oItem = Create(&PantsC,#translation=iColor);}
      else if  iRandom <= 100 {oItem = Create(&PantsA); Send(oItem,@Randomize);}
      else if  iRandom <= 125 {oItem = Create(&Skirt); Send(oItem,@Randomize);}
      else                    {oItem = Create(&ShortSkirt); Send(oItem,@Randomize);}
      Send(self,@AddEquipmentObject,#what=oItem);

      // Shirt
      if Random(0,1)          {oItem = Create(&Tanktop); Send(oItem,@Randomize);}
      else                    {oItem = Create(&Shirt); Send(oItem,@Randomize);}
      Send(self,@AddEquipmentObject,#what=oItem);

      // Torch
      // Just pack one in case. Not using it just yet.
      oItem = Create(&Torch);
      Send(self,@NewHold,#what=oItem);

      return;
   }

   CreateTreasure()
   {
      return;
   }

   // Friend of all newbies and our leader of course.
   IsAlliedClass(what=$)
   {
      if IsClass(what,&Player)
         AND ((what = poLeader)
            OR (Send(what,@GetBaseMaxHealth) < Send(SETTINGS_OBJECT,@GetPKillEnableHP)))
      {
         return TRUE;
      }

      return FALSE;
   }

   // Can't attack players.
   AllowBattlerAttack(victim=$)
   {
      // Must be in a room to attack, must have target.
      if (poOwner = $
         OR victim = $)
      {
         return FALSE;
      }

      // Can't attack players or their minions.
      if IsClass(victim,&Player)
         OR Send(victim,@IsOwnedByPlayer)
      {
         return FALSE;
      }

      propagate;
   }

   // Followers can be given items to use.
   CanAcceptOffer(who=$)
   {
      return (who = poLeader) OR IsClass(who,&DM);
   }

   ReqOffer(what = $)
   {
      if (what = poLeader) OR IsClass(what,&DM)
      {
         return TRUE;
      }

      return FALSE;
   }

   Offer(what = $)
   {
      if (what = poLeader) OR IsClass(what,&DM)
      {
         Send(what,@CounterOffer,#item_list=$);
      }

      return;
   }

   // Put items to use or store them for future use.
   AcceptOffer()
   {
      local i,oHolder,lTake_items;

      // take stuff the user put there
      oHolder = Send(SYS,@GetSystemHolder1);
      foreach lTake_items in [ Send(oHolder,@GetHolderActive),
                           Send(oHolder,@GetHolderPassive) ]
      {
         foreach i in lTake_items
         {
            Send(self,@NewHold,#what=i);

            // Try to put on any received items.
            // No ranged weapons or lutes though. Possibly later.
            if IsClass(i,&RangedWeapon)
               OR IsClass(i,&Ammo)
               OR IsClass(i,&Lute)
               OR IsClass(i,&Torch)
               OR (IsClass(i,&Shield)
                  AND GetListElemByClass(plUsing,&Torch) <> $)
               OR NOT Send(self,@TryUseItem,#what=i)
            {
               // If we can't, return them.
               Send(poLeader,@NewHold,#what=i);
            }
         }
      }

      // kill the cancel offer timer
      Send(self,@OfferCanceled);

      return TRUE;
   }

   IsUsingA(class=$)
   {
      return GetListElemByClass(plUsing,class) <> $;
   }

   NewUsing(what = $)
   {
      Send(self,@ComputeMaxMana);

      propagate;
   }

   UnuseItem(what=$,bDrop=TRUE)
   {
      local i;

      foreach i in plUsing
      {
         if i = what
         {
            plUsing = DelListElem(plUsing,i);

            Send(what,@NewUnused,#what=self);

            if (IsClass(what,&Weapon))
            {
               Send(self,@RemoveWeaponAction,#what=what);
            }

            if bDrop
            {
               Send(poOwner,@NewHold,#what=what,#new_row=piRow,#new_col=piCol,
                     #fine_row=piFine_row+2,#fine_col=piFine_col+2);
            }

            Send(self,@ComputeMaxMana);

            return TRUE;
         }
      }

      return FALSE;
   }

   SetLeader(oLeader=$,report=TRUE,bContracted=FALSE)
   {
      local i, oObject;

      // Time for a farewell...
      if (poLeader <> $) AND (oLeader = $)
      {
         // Let's return all the stuff.
         foreach i in plUsing
         {
            if NOT (IsClass(i,&ShirtBase)
               OR IsClass(i,&Pants)
               OR IsClass(i,&Torch))
            {
               plUsing = DelListElem(plUsing,i);

               Send(i,@NewUnused,#what=self);

               Send(poOwner,@NewHold,#what=i,#new_row=piRow,#new_col=piCol,
                     #fine_row=piFine_row+2,#fine_col=piFine_col+2);
            }
         }

         // Check if we still have a shield stashed somewhere.
         foreach i in plPassive
         {
            oObject = Send(self,@HolderExtractObject,#data=i);

            if IsClass(oObject,&Shield)
               AND NOT IsClass(oObject,&Torch)
            {
               break;
            }
            else
            {
               oObject = $;
            }
         }

         if oObject <> $
         {
            Send(poOwner,@NewHold,#what=oObject,#new_row=piRow,#new_col=piCol,
                  #fine_row=piFine_row+2,#fine_col=piFine_col+2);
         }

         if ptAction <> $
         {
            DeleteTimer(ptAction);
         }

         ptAction = CreateTimer(self,@FareWellCruelWorld,10000);
      }

      propagate;
   }

   FareWellCruelWorld()
   {
      ptAction = $;

      Post(self,@Delete);

      return;
   }

   // Follower was knocked out. Let's put him on a timeout before
   // he rejoins his leader. If the leader is nowhere in sight,
   // return to him the next time he enters a safe room.
   Killed(what=$,bPvP=FALSE)
   {
      local oBody;

      if poOwner <> $
      {
         oBody = Send(self,@CreateDeadBody,#killer=self);

         if oBody <> $
         {
            Send(poOwner,@NewHold,#what=oBody,#new_row=piRow,#new_col=piCol,
                  #fine_row=piFine_row,#fine_col=piFine_col,
                  #new_angle=Send(self,@GetAngle));

            // Let's keep track of our body in case we are summoned.
            poBody = oBody;
         }

         if bPvP
         {
            Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_pvp);
         }
         else if vrSound_death <> $
         {
            Send(poOwner,@SomethingWaveRoom,#what=oBody,#wave_rsc=vrSound_death,
                  #flags=SOUND_RANDOM_PITCH);
         }

         Send(self,@FollowerAbsence);
      }

      return;
   }

   // Followers don't decompose and create a special body.
   CreateDeadBody(killer=$)
   {
      // Send current pant/shirt color to body only if they both use
      // the new two-color xlats. Otherwise, Send default colors.
      if Send(SYS,@IsTwoColorXLAT,#xlat=Send(self,@GetBodyTranslation))
         AND Send(SYS,@IsTwoColorXLAT,#xlat=Send(self,@GetLegsTranslation))
      {
         return Create(&DeadBody,#victim=self,#killer=killer,#Decomposes=FALSE,
                     #bFollower=TRUE,#PlayerBodyOverlay=vrDead_Legs,
                     #BodyTranslation=Send(self,@GetBodyTranslation),
                     #LegsTranslation=Send(self,@GetLegsTranslation));
      }

      return Create(&DeadBody,#victim=self,#killer=killer,#Decomposes=FALSE,
                     #bFollower=TRUE,#PlayerBodyOverlay=vrDead_Legs,
                  #BodyTranslation=Send(self,@GetDefaultShirtTranslation),
                  #LegsTranslation=Send(self,@GetDefaultPantsTranslation));
   }

   FollowerAbsence(iDelay=FALSE,timer = $)
   {
      local i;

      if (ptAbsence <> $) AND (ptAbsence <> timer)
      {
         DeleteTimer(ptAbsence);
      }

      ptAbsence = $;

      if iDelay
      {
         ptAbsence = CreateTimer(self,@FollowerAbsence,iDelay);

         return;
      }

      // Enchantments must be removed before brain gets set to $.
      Send(self,@RemoveAllEnchantments);

      // Same goes for over time effects.
      Send(self,@DeleteAllOverTimeEffects);

      // If the follower has an Evil Twin, delete it too.
      Send(self,@RemoveAttackingEvilTwin);

      // If the follower has Apparitions attacking it, delete them.
      Send(self,@RemoveAllApparitions);

      // If the follower had any minions, remove them.
      Send(self,@RemoveAllMinions);

      foreach i in plHurtMeRecently
      {
         if IsTimer(Nth(i,3))
         {
            DeleteTimer(Nth(i,3));
         }
         SetFirst(i,$);
         SetNth(i,3,$);
      }
      plHurtMeRecently = $;

      // Delete our resource timers.
      if ptHealth <> $
      {
         DeleteTimer(ptHealth);
         ptHealth = $;
      }

      if ptMana <> $
      {
         DeleteTimer(ptMana);
         ptMana = $;
      }

      if ptVigor <> $
      {
         DeleteTimer(ptVigor);
         ptVigor = $;
      }

      Send(self,@EnterStateLimbo);

      Send(self,@ClearBasicTimers);

      if ptAction <> $
      {
         DeleteTimer(ptAction);
         ptAction = $;
      }

      poLastAttacker = $;

      // Let's get out of here!
      if poOwner <> $
      {
         Send(poOwner,@LeaveHold,#what=self);
         poOwner = $;
      }

      return;
   }

   FollowerReturn(oBody=$)
   {
      local oOwner;

      // Just a precaution. Followers shouldn't occupy the merc slot
      // if the feature is disabled.
      if NOT Send(SETTINGS_OBJECT,@IsFollowerEnabled)
      {
         return;
      }

      // Got a body, so we must have died somewhere along the road.
      if oBody <> $
      {
         oOwner = Send(oBody,@GetOwner);

         // Let's check if our master had the decency to stick around our
         // unconscious body. If so, revive at our body.
         if (oOwner = Send(poLeader,@GetOwner))
            AND Send(poLeader,@CanHelpPlayerStrict,#bFollower=TRUE)
         {
            Send(oOwner,@NewHold,#what=self,
               #new_row=Send(oBody,@GetRow),#new_col=Send(oBody,@GetCol));

            Send(self,@GainHealth,#amount=piMax_health*50/100);

            Send(self,@UpdateRates);

            Send(self,@FollowerReturnMessage,#what=poLeader,#bDeath=TRUE);
         }
      }
      // Not called by our corpse. That means our leader has entered a
      // safe house. Let's join him again.
      else
      {
         // If we meet up with our follower in a safe place
         // before his corpse has poofed, tie up loose ends
         // and dispose of the corpse and it's revival timer.
         if poBody <> $
         {
            Send(poBody,@DeleteTimerMessage);
         }

         oOwner = Send(poLeader,@GetOwner);

         Send(oOwner,@NewHold,#what=self,
            #new_row=Send(oOwner,@GetTeleportRow),
            #new_col=Send(oOwner,@GetTeleportCol));

         Send(self,@GainHealth,#amount=piMax_health*50/100);

         Send(self,@UpdateRates);

         Send(self,@FollowerReturnMessage,#what=poLeader);
      }

      poBody = $;

      return;
   }

   FollowerReturnMessage(what=$,bDeath=FALSE)
   {
      if bDeath
      {
         Post(self,@MercenarySayToOne,#target=what,#message_rsc=vrFollowerReturnDeath);
      }
      else
      {
         Post(self,@MercenarySayToOne,#target=what,#message_rsc=vrFollowerReturnLost);

         Send(self,@FaceLeader);

         if IsClass(self,&Human)
         {
            Send(self,@DoWave);
         }
      }

      return;
   }

   SomethingEntered(what = $,where=$)
   {
      if what = poLeader
      {
         if ptAbsence <> $
         {
            DeleteTimer(ptAbsence);
            ptAbsence = $;
         }

         Send(self,@GreetLeader);
      }

      propagate;
   }

   IsAbsent()
   {
      return (poOwner = $);
   }

   // Some modifications from default creation.
   SetResources()
   {
      // Health
      piMax_health = viLevel * Bound(75 + piStamina,$,125) / 100;
      piHealth = piMax_health * 100;

      // Mana
      piMax_mana = (150 + 2 * piMysticism)/10;
      piMana = piMax_mana * 100;

      // Vigor
      piMax_vigor = 200;
      piVigor_rest_threshold = 200;
      piVigor = piMax_vigor * 100;

      // Combat stats
      piMeleeRange = viMeleeRange;
      piFireRange = viFireRange * (75 + piAim) / 100;
      piSpellPower = Bound((piIntellect + piMysticism) / 2, 0, 50) + viSpellPower;
      piVisionDistance = viVisionDistance + (piIntellect + piAim) / 20;
      viNaturalVigorRegeneration = 500 + piStamina * 10;

      return;
   }

   FollowerDing(bCreation=FALSE)
   {
      local iSpell, oSpell, iMana, iExertion, iPriority, iPower, iAttacks, iCount, iLevelPercentage;

      iLevelPercentage = 100*Send(poLeader,@GetBaseMaxHealth)/(100 + Send(poLeader,@GetRawStamina));
      viLevel = FOLLOWER_MAX_LEVEL*iLevelPercentage/100;
      piMax_health = (100 + piStamina)*iLevelPercentage/100;

      // Automatic capping takes care of the rest.
      Send(self,@GainHealth,#amount=200);
      Send(self,@GainMana,#amount=200);
      Send(self,@GainVigor,#amount=200);

      // Update our combat abilities depending on role.
      if piRole = FOLLOWER_ROLE_WARRIOR
      {
         if viLevel < FOLLOWER_EXPERIENCED
         {
            iAttacks = ATTACK_SLASH;
         }
         else if viLevel < FOLLOWER_SEASONED
         {
            iAttacks = ATTACK_SLASH | ATTACK_TAUNT; 
         }
         else if viLevel < FOLLOWER_HARDENED
         {
            iAttacks = ATTACK_SLASH | ATTACK_TAUNT | ATTACK_WEAKEN;
         }
         else if viLevel < FOLLOWER_VETERAN
         {
            iAttacks = ATTACK_SLASH | ATTACK_TAUNT | ATTACK_WEAKEN | ATTACK_FRIGHTEN; 
         }
         else
         {
            iAttacks = ATTACK_SLASH | ATTACK_TAUNT | ATTACK_WEAKEN | ATTACK_FRIGHTEN | ATTACK_STUN; 
         }

         // Update our list of default attacks if necessary.
         if iAttacks <> viAttacks
         {
            viAttacks = iAttacks;
            Send(self,@AddDefaultAttacks,#bUpdate=TRUE);
         }

         viBonusSwing = viLevel*FOLLOWER_EFFECT_CHANCE_TRUE/FOLLOWER_EFFECT_BASE;
         viBleedChance = viLevel*FOLLOWER_EFFECT_CHANCE_FAIR/FOLLOWER_EFFECT_BASE;
      }

      if piRole = FOLLOWER_ROLE_BARD
      {
         if viLevel < FOLLOWER_EXPERIENCED
         {
            iAttacks = ATTACK_SLASH;
         }
         else if viLevel < FOLLOWER_SEASONED
         {
            iAttacks = ATTACK_SLASH | ATTACK_SNARE; 
         }
         else if viLevel < FOLLOWER_HARDENED
         {
            iAttacks = ATTACK_SLASH | ATTACK_SNARE | ATTACK_DISTRACT;
         }
         else
         {
            iAttacks = ATTACK_SLASH | ATTACK_SNARE | ATTACK_DISTRACT | ATTACK_DAZE; 
         }

         // Update our list of default attacks if necessary.
         if iAttacks <> viAttacks
         {
            viAttacks = iAttacks;
            Send(self,@AddDefaultAttacks,#bUpdate=TRUE);
         }

         viPoisonChance = viLevel*FOLLOWER_EFFECT_CHANCE_HIGH/FOLLOWER_EFFECT_BASE;
         viBonusSwing = viLevel*FOLLOWER_EFFECT_CHANCE_GOOD/FOLLOWER_EFFECT_BASE;
      }

      if piRole = FOLLOWER_ROLE_WARLOCK
      {
         if viLevel < FOLLOWER_SEASONED
         {
            iAttacks = ATTACK_SLASH;
         }
         else if viLevel < FOLLOWER_VETERAN
         {
            iAttacks = ATTACK_SLASH | ATTACK_CRIPPLE; 
         }
         else
         {
            iAttacks = ATTACK_SLASH | ATTACK_CRIPPLE | ATTACK_FRIGHTEN; 
         }

         // Update our list of default attacks if necessary.
         if iAttacks <> viAttacks
         {
            viAttacks = iAttacks;
            Send(self,@AddDefaultAttacks,#bUpdate=TRUE);
         }

         viSiphonChance = viLevel*FOLLOWER_EFFECT_CHANCE_GOOD/FOLLOWER_EFFECT_BASE;
      }

      if piRole = FOLLOWER_ROLE_WIZARD
      {
         viBurnChance = viLevel*FOLLOWER_EFFECT_CHANCE_FAIR/FOLLOWER_EFFECT_BASE;
      }

      if piRole = FOLLOWER_ROLE_PRIEST
      {
         viFatigueChance = viLevel*FOLLOWER_EFFECT_CHANCE_GOOD/FOLLOWER_EFFECT_BASE;
      }

      iCount = Length(Send(self,@GetSpellObjects));

      // We are starting at level 25, hence iCount + 4.
      while (viLevel / 5 > iCount + 4)
      {
         iMana = 100;
         iExertion = 100;
         iPriority = 100;
         iPower = 25 + viDifficulty*5;

         iSpell = Send(self,@GetNewSpellID,#iRank=iCount+1);

         if iSpell
         {
            oSpell = Send(SYS,@FindSpellByNum,#num=iSpell);

            // Special modifications on a role by role basis...
            if (IsClass(oSpell,&AttackSpell) AND ((piRole = FOLLOWER_ROLE_WIZARD) OR (piRole = FOLLOWER_ROLE_WARLOCK)))
               OR (IsClass(oSpell,&Jala) AND (piRole = FOLLOWER_ROLE_BARD))
               OR (IsClass(oSpell,&Heal) AND (piRole = FOLLOWER_ROLE_PRIEST))
               OR ((IsClass(oSpell,&PersonalEnchantment) OR (iSpell = SID_RELAY)) AND (piRole = FOLLOWER_ROLE_WARRIOR))
               OR (Send(oSpell,@IsIllusion) AND (piRole = FOLLOWER_ROLE_WARLOCK))
            {
               iMana = FOLLOWER_SPECIALIZED_MANA_PERCENTAGE;
               iExertion = FOLLOWER_SPECIALIZED_EXERTION_PERCENTAGE;
               iPriority = 10000/FOLLOWER_SPECIALIZED_FREQUENCY_PERCENTAGE;
               iPower = Bound(iPower*FOLLOWER_SPECIALIZED_POWER_PERCENTAGE/100,$,99);
            }
         }

         if Send(self,@AddCombatAction,#iNum=iSpell,
                                       #iMana=iMana,
                                       #iExertion=iExertion,
                                       #iPriority=iPriority,
                                       #iPower=iPower)
         {
            if NOT bCreation
            {
               Send(self,@FollowerLearnMessage,#iNum=iSpell);
            }

            ++iCount;
         }
         else
         {
            break;
         }
      }

      return;
   }

   ComputeMaxMana()
   {
      local i, index, iNodeList, oNode, iMagic;

      if poLeader = $
      {
         return;
      }

      iMagic = Send(self,@GetMysticism);
      piMax_mana = 150 + (2 * iMagic);

      for (index = 1, iNodelist = Send(poLeader,@GetNodeList);
           iNodeList > 0 AND index <= NODE_MAX_VALUE;
           index *= 2)
      {
         if (iNodeList & index)
         {
            oNode = Send(SYS,@FindNodeByNum,#num=index);
            piMax_mana += Send(oNode,@GetManaAdjust,#who=self,#myst=iMagic);
            iNodelist &= ~index;
         }
      }

      piMax_mana /= 10;

      // Account for any items that may affect max mana
      foreach i in plUsing
      {
         if Send(i,@AdjustsMaxMana)
         {
            piMax_mana += Send(i,@GetManaChange);
         }
      }

      foreach i in plEnchantments
      {
         if Send(Nth(i,2),@AffectsMaxMana)
         {
            piMax_mana += Send(Nth(i,2),@GetManaBonus,#state=Nth(i,3));
         }
      }

      Send(self,@NewMana);

      return;
   }

   GetNewSpellID(iRank=0)
   {
      local iSpell;

      switch(iRank)
      {
         case 1:
            switch(piRole)
            {
               case FOLLOWER_ROLE_BARD:
                  iSpell = SID_GLOW;
                  break;
               case FOLLOWER_ROLE_WARRIOR:
                  iSpell = SID_RELAY;
                  break;
               case FOLLOWER_ROLE_WIZARD:
                  iSpell = SID_LIGHT;
                  break;
               case FOLLOWER_ROLE_PRIEST:
                  iSpell = SID_MINOR_HEAL;
                  break;
               case FOLLOWER_ROLE_WARLOCK:
                  iSpell = SID_SHADOW_FORM;
                  break;
            }
            break;

         case 2:
            switch(piRole)
