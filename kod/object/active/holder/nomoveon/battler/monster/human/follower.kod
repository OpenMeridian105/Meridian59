   // No nuking poor followers!
   DMCanArmageddon()
   {
      return FALSE;
   }

   //// The following messages deal with follower chatter.
   // Every time the follower wants to chat randomly, he asks ChatTimer.
   // This prevents the follower from excessive spamming of messages.
   ChatTimer(timer=FALSE)
   {
      if (ptChat = timer)
      {
         ptChat = $;

         return;
      }

      if (ptChat <> $)
      {
         return FALSE;
      }

      ptChat = CreateTimer(self,@ChatTimer,FOLLOWER_CHAT_DELAY);

      return TRUE;
   }

   // Called upon the follower killing something.
   // Currently every third kill in average will be commented on.
   // Will check for special kill messages first though.
   KilledSomething(what=$,use_weapon=$)
   {
      local iInfo;

      // Avoids errors when follower is dismissed mid combat.
      if poLeader = $
      {
         propagate;
      }

      poInfo = what;

      iInfo = MONSTER_INFO_KILLED;

      if Send(poLeader,@UserDisplayMobQuestActive,#what=what)
      {
         iInfo |= MONSTER_INFO_QUEST;
      }

      if Send(self,@GiveInfo,#iInfo=iInfo)
      {
         propagate;
      }

      if NOT iInfo
         AND NOT Random(0,FOLLOWER_KILLED_SOMETHING_CHAT_CHANCE*100/viChat_frequency)
         AND (use_weapon <> $)
         AND IsClass(use_weapon,&Weapon)
         AND Send(self,@ChatTimer)
      {
         switch(Random(1,6))
         {
            case 1:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_killed_something_a);
               break;
            case 2:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_killed_something_b);
               break;
            case 3:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_killed_something_c);
               break;
            case 4:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_killed_something_d,
                  #parm1=Send(use_weapon,@GetName));
               break;
            case 5:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_killed_something_e);
               break;
            case 6:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_killed_something_f,
                  #parm1=Send(use_weapon,@GetName));
               break;
         }
      }

      propagate;
   }

   // Called upon the leader killing something.
   // Currently every fourth kill in average will be commented on.
   LeaderKilledSomething(what=$,use_weapon=$)
   {
      local iInfo;

      poInfo = what;

      iInfo = MONSTER_INFO_KILLED;

      if Send(poLeader,@UserDisplayMobQuestActive,#what=what)
      {
         iInfo |= MONSTER_INFO_QUEST;
      }

      if Send(self,@GiveInfo,#iInfo=iInfo)
      {
         return;
      }

      if NOT iInfo
         AND NOT Random(0,FOLLOWER_LEADER_KILLED_SOMETHING_CHAT_CHANCE*100/viChat_frequency)
         AND (use_weapon <> $)
         AND IsClass(use_weapon,&Weapon)
         AND Send(self,@ChatTimer)
      {
         switch(Random(1,6))
         {
            case 1:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_leader_killed_something_a);
               break;
            case 2:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_leader_killed_something_b);
               break;
            case 3:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_leader_killed_something_c);
               break;
            case 4:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_leader_killed_something_d,
                  #parm1=Send(use_weapon,@GetName));
               break;
            case 5:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_leader_killed_something_e);
               break;
            case 6:
               Post(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_leader_killed_something_f,
                  #parm1=Send(use_weapon,@GetName));
               break;
         }
      }

      return;
   }

   MonsterEndCombat()
   {
      Send(self,@FollowerRetreat);

      propagate;
   }

   // Called when the leader runs for it.
   // Currently triggered every time.
   FollowerRetreat()
   {
      local iInfo;

      // Avoids errors when follower is dismissed mid combat.
      if poLeader = $
      {
         return;
      }

      poInfo = poTarget;

      iInfo = MONSTER_INFO_RETREATING;

      if Send(poLeader,@UserDisplayMobQuestActive,#what=poTarget)
      {
         iInfo |= MONSTER_INFO_QUEST;
      }

      if Send(self,@GiveInfo,#iInfo=iInfo)
      {
         return;
      }

      if Send(self,@ChatTimer) AND NOT Send(self,@GiveInfo,#iInfo=iInfo)
      {
         switch(Random(1,4))
         {
            case 1:
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_retreat_a);
               break;
            case 2:
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_retreat_b);
               break;
            case 3:
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_retreat_c);
               break;
            case 4:
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_retreat_d,
                  #parm1=Send(poTarget,@GetName));
               break;
         }
      }

      return;
   }

   // Called when the follower is injured beyond a threshold.
   // Currently triggered every time.
   MercenaryInjured(iThreshold=$)
   {
      switch(iThreshold)
      {
         case 0:
            Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_injured_a);
            break;
         case 1:
            Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_injured_b);
            break;
         case 2:
            if Send(self,@ChatTimer)
            {
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_injured_c);
            }
            break;
         case 3:
            if Send(self,@ChatTimer)
            {
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_injured_d);
               Send(self,@DoWave);
            }
            break;
      }

      return;
   }

   // Called when the follower recovers beyond a threshold.
   // Currently triggered every time.
   MercenaryRecovered(iThreshold=$)
   {
      if Send(self,@ChatTimer)
      {
         switch(iThreshold)
         {
            case 1:
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_recovered_a);
               break;
            case 2:
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_recovered_b);
               break;
            case 3:
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_recovered_c);
               break;
            case 4:
               Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_recovered_d);
               break;
         }
      }

      return;
   }

   // Called when the follower enters combat.
   // Currently triggered every time, if enough time has passed.
   FollowerEnterCombat(target=$)
   {
      local iInfo;

      // Avoids errors when follower is dismissed mid combat.
      if poLeader = $
      {
         return;
      }

      poInfo = target;

      iInfo = MONSTER_INFO_ENGAGED;

      if Send(poLeader,@UserDisplayMobQuestActive,#what=target)
      {
         iInfo |= MONSTER_INFO_QUEST;
      }

      if Send(self,@GiveInfo,#iInfo=iInfo)
      {
         return;
      }

      if Send(self,@ChatTimer)
      {
         // Looks like we have nothing meaningful to say about this enemy. Hence, battlecry!
         if (GetTime() - piCombatCheck < FOLLOWER_CONTINUOUS_COMBAT)
         {
            if NOT Random(0,FOLLOWER_ENTER_CONTINUOUS_COMBAT_CHANCE*100/viChat_frequency)
            {
               switch(Random(1,6))
               {
                  case 1:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_a_a);
                     break;
                  case 2:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_a_b);
                     break;
                  case 3:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_a_c);
                     break;
                  case 4:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_a_d);
                     break;
                  case 5:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_a_e);
                     break;
                  case 6:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_a_f);
                     break;
               }
               return;
            }
         }
         else if (GetTime() - piCombatCheck < FOLLOWER_BRIEF_PAUSE)
         {
            if NOT Random(0,FOLLOWER_ENTER_BRIEF_PAUSE_CHANCE*100/viChat_frequency)
            {
               switch(Random(1,3))
               {
                  case 1:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_b_a);
                     break;
                  case 2:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_b_b);
                     break;
                  case 3:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_b_c);
                     break;
               }
               return;
            }
         }
         else if (GetTime() - piCombatCheck < FOLLOWER_EXTENDED_PAUSE)
         {
            if NOT Random(0,FOLLOWER_ENTER_EXTENDED_PAUSE_CHANCE*100/viChat_frequency)
            {
               switch(Random(1,3))
               {
                  case 1:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_c_a);
                     break;
                  case 2:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_c_b);
                     break;
                  case 3:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_c_c);
                     break;
               }
               return;
            }
         }
         else if (GetTime() - piCombatCheck < FOLLOWER_LONG_PAUSE)
         {
            if NOT Random(0,FOLLOWER_ENTER_LONG_PAUSE_CHANCE*100/viChat_frequency)
            {
               switch(Random(1,3))
               {
                  case 1:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_d_a);
                     break;
                  case 2:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_d_b);
                     break;
                  case 3:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_d_c);
                     break;
               }
               return;
            }
         }
         else
         {
            if NOT Random(0,FOLLOWER_ENTER_INACTIVITY_CHANCE*100/viChat_frequency)
            {
               switch(Random(1,7))
               {
                  case 1:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_e_a);
                     break;
                  case 2:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_e_b);
                     break;
                  case 3:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_e_c);
                     break;
                  case 4:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_e_d);
                     break;
                  case 5:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_e_e);
                     break;
                  case 6:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_e_f);
                     break;
                  case 7:
                     Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_e_g);
                     break;
               }

               return;
            }
         }

         // These are generic battle cries that don't depend on time and that come up when
         // a time dependent trigger doesn't pass its random check. Simply for variety.
         if NOT Random(0,FOLLOWER_ENTER_RANDOM_CHANCE*100/viChat_frequency)
         {
            switch(Random(1,10))
            {
               case 1:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_a);
                  break;
               case 2:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_b);
                  break;
               case 3:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_c);
                  break;
               case 4:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_d);
                  break;
               case 5:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_e);
                  break;
               case 6:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_f);
                  break;
               case 7:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_g);
                  break;
               case 8:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_h);
                  break;
               case 9:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_i);
                  break;
               case 10:
                  Send(self,@MercenarySayToOne,#target=poLeader,#message_rsc=follower_entered_combat_f_j);
                  break;
            }
         }
      }

      return;
   }

   CountsAsHero()
   {
      return TRUE;
   }

   GetMoveOnType()
   {
      return MOVEON_YES;
   }

   // Followers can't be harmed by players.
   AssessDamage(what = $)
   {
      if IsClass(what,&Player)
      {
         return 0;
      }

      propagate;
   }

   StartOverTimeEffect(who=0,strength=0)
   {
      if (strength < 0)
         AND who <> 0
         AND IsClass(who,&Player)
      {
         return;
      }

      propagate;
   }

   ChangeLooks(bHair=TRUE,bFace=TRUE,bClothes=TRUE)
   {
      local bChange;

      bChange = FALSE;

      if bHair
      {
         Send(self,@SetHair);
         bChange = TRUE;
      }

      if bFace
      {
         Send(self,@SetFace);
         bChange = TRUE;
      }

      if bClothes
      {
         Send(self,@SetClothes);
         bChange = TRUE;
      }

      if bChange
      {
         Send(self,@RefreshPlayerVisualGear);
      }

      return;
   }

   DropGear(bArmor=TRUE,bWeapon=TRUE,bClothes=TRUE)
   {
      local i;

      foreach i in plUsing
      {
         if (bArmor AND (IsClass(i,&Armor) OR IsClass(i,&Helmet)))
            OR (bWeapon AND (IsClass(i,&Weapon) OR IsClass(i,&Shield)))
            OR (bClothes AND (IsClass(i,&Pants) OR IsClass(i,&ShirtBase)))
         {
            plUsing = DelListElem(plUsing,i);

            Send(i,@NewUnused,#what=self);

            Send(poOwner,@NewHold,#what=i,#new_row=piRow,#new_col=piCol,
                  #fine_row=piFine_row+2,#fine_col=piFine_col+2);
         }
      }

      Send(self,@ComputeMaxMana);

      return;
   }

   AddHurtMeRecently(who=$)
   {
      if IsClass(who,&Player)
      {
         return;
      }

      propagate;
   }

   UpdateTimeValues()
   {
      piOutOfCombatAction = GetTime();
      piCombatCheck = GetTime();

      return;
   }

   IsOfferingLift()
   {
      return TRUE;
   }

   CanLift(what=$)
   {
      if NOT Send(SETTINGS_OBJECT,@IsLiftEnabled)
      {
         return FALSE;
      }

      // We can only lift our leader.
      if (what = poLeader)
      {
         return TRUE;
      }

      return FALSE;
   }

   IsOwnedByPlayer()
   {
      return TRUE;
   }

end
