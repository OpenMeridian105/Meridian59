follower_commands_basic = de \
   "Die folgenden Befehle k霵nen direkt in den Chat eingegeben werden.  "
   "Die meisten k霵nen abgek僡zt werden: '~I~Bs~I~B' f僡 '~Isagen~I', "
   "'~I~Bm~I~B' for '~Imitteilen~I'...\n"
   "~Bsagen~B (Nachricht)   ~Isendet eine Nachricht an alle in demselben Raum~I\n"
   "~Btelephatie~B (Spielername) (Nachricht)   ~Isendet eine Direktnachricht an einen Spieler~I\n"
   "~Brufen~B (Nachricht)   ~Isendet eine Nachricht, die in den benachbarten R酳men geh顤t wird~I\n"
   "~Bmitteilent~B (Nachricht)   ~Isendet eine Nachricht an alle, die eingeloggt sind~I\n\n"
   "~Bzaubern~B (Zaubersname)   ~Izaubert den angegebenen Zauber~I\n"
   "~Bausf𢞴ren~B (Fertigkeitsname)   ~If𢞴rt die F鄣igkeit aus (nur aktive F鄣igkeiten)~I\n"
   "~Brasten/aufstehen~B   ~Ierlaubt es dir, schneller wieder zu Kr輎ten zu kommen~I\n\n"
   "~Bnehmen~B   ~Izeigt eine Liste mit Gegenst鄚den in deiner Reichweite, die du vom Boden aufnehmen kannst~I\n"
   "~Bweg~B   ~Izeigt eine Liste von Gegenst鄚den aus deinem Inventar an, die du fallen lassen kannst~I\n"
   "~Bkaufen~B   ~I鐪fnet ein Einkaufsfenster bei einem NPC~I\n"
   "~Banbieten~B   ~zeigt eine Liste Gegenst鄚de aus deinem Inventar, die du einem anderen Spieler oder NPC anbieten kannst~I\n\n"
   "~Bwer~B   ~Izeigt eine Liste von Spielern, die zur Zeit im Spiel eingeloggt sind~I\n"
   "~Bmail~B   ~I鐪fnet deine pers霵lichen Mails~I\n"
   "~Bhilfe~B   ~I鐪fnet die Hilfe Seite bzw. das Meridian Wiki~I\n"
   "~Bbeenden~B   ~Iloggt dich aus und bringt dich zur Charakter Auswahl zur𡡷k~I\n\n"
   "~IWenn Du weitere Befehle wissen willst, gebe Folgendes ein ~B's erweiterte Befehle'~B, "
   "~B's soziale Befehle'~B, ~B's Einstelllungsbefehle'~B oder ~B's gesprochene Befehle'~B!"

follower_commands_advanced = de \
   "Dies sind erweiterte Befehle, die du sp酹er eventuell hilfreich finden wirst...\n"
   "~Beinzahlen~B (Menge)   ~Izahlt die Menge an Schillingen bei einem B鄚ker ein~I\n"
   "~Babheben~B (Menge)   ~Ihebt die Menge an Schillingen bei einem B鄚ker ab~I\n"
   "~Bkontostand~B   ~Izeigt deinen aktuellen Kontostand bei einem B鄚ker an~I\n\n"
   "~Bbenutzen~B   ~Iaktiviert das Objekt oder zeigt den Inhalt des Containers an~I\n"
   "~Bablegen~B   ~Izeigt Gegenst鄚de aus deinem Inventar an, um sie in einen Container zu legen~I\n\n"
   "~Bbefehle~B   ~I鐪fnent ein Fenster, um deine F-Tasten als Hotkeys zu organisieren~I\n"
   "~Bcmdalias~B   ~I鐪fnent ein Fenster, um deine Befehlsk僡zel zu organisieren~I\n\n"
   "~Bkarte~B   ~Iwechselt die Anzeige zu einer gro絽n Karte im Hauptfenster ~I\n\n"
   "~Bzeit~B   ~Idruckt die aktuelle Zeit im Spiel ~I\n\n"
