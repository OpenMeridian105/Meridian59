follower_one_spell_inform = de "Bislang habe ich folgenden Zauber gelernt "
follower_spell_inform = de "Bislang habe ich folgende Zauber gelernt "
follower_and = de " und "
follower_comma = de ", "
follower_spell = de "~I~B%s~I~B"
follower_say_start = de "~MDein Begleiter teilt dir mit, \""
follower_say_end = de ".~n~M\""

// Messaged used by GiveInfo() triggered by MercenaryCommand()
follower_info = de "%s%s"
follower_info_repeat_none = de ""
follower_info_repeat_a = de "Okay, wie ich bereits sagte... "
follower_info_repeat_b = de "Ich glaube, ich wiederhole mich, aber... "
follower_info_repeat_c = de "Noch mal..."
follower_info_none = de \
   "Es tut mir leid, aber ich habe keine brauchbaren Informationen zu diesem Ort.  Sorry!"

follower_greet_leader_template = de "%s%s%s"
follower_greet_leader_a = de "Hallo, "
follower_greet_leader_b = de "Gut dich zu sehen, "
follower_greet_leader_c = de "Hallo, "
follower_greet_leader_end_a = de "!"
follower_greet_leader_end_b = de "."
follower_greet_leader_end_c = de "..."

follower_brief_leader_requested_none = de \
   "Ich habe meine Notizen mehrfach geprüft, aber es sieht so aus als ob... wir nichts zu tun haben?  "
   "Das kann nicht richtig sein!  Lass uns schleunigst etwas finden!"
follower_brief_leader_requested_template = de "%s%s%s%s"
follower_brief_leader_requested_template_combined = de "%s%s%s%s%s%s%s"
follower_brief_leader_requested_start_a = de "Lass mich meine Notizen prüfen, ich habe mir notiert..."
follower_brief_leader_requested_start_b = de "Meine Notizen besagen..."
follower_brief_leader_requested_start_c = de "Wenn ich mich richtig erinnere, hatten wir den Auftrag..."
follower_brief_leader_requested_start_d = de "Ich galube mich zu erinnern, das wir Folgendes zu tun haben..."
follower_brief_leader_requested_start_e = de "Wo ist mein Reise Tagebuch? Ah, da ist es! Da steht..."
follower_brief_leader_requested_kill = de "~MDein Begleiter teilt dir mit, \"...töte "
follower_brief_leader_requested_tame  = de "~MDein Begleiter teilt dir mit, \"... zähme "
follower_brief_leader_requested_visit = de "~MDein Begleiter teilt dir mit, \"...besuche "
follower_brief_leader_requested_obtain = de "~MDein Begleiter teilt dir mit, \"... erhalte "
follower_brief_leader_requested_deliver = de " und liefere "
follower_brief_leader_requested_period = de ".~n~M\""
follower_brief_leader_requested_end_a = de "Das ist bereits alles."
follower_brief_leader_requested_end_b = de "Das scheint alles zu sein."
follower_brief_leader_requested_end_c = de "Ansonsten... nichts."
follower_brief_leader_requested_end_d = de "Das sollte alles sein."
