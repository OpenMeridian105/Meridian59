lostsoul_name_rsc = de "Poltergeist"
lostsoul_desc_rsc = de \
   "Dieser erzürnte Geist scheint in der Welt der Lebenden gefangen "
   "zu sein.  Vielleicht hat er noch eine Aufgabe zu erledigen, bevor "
   "es ihm gestattet ist, die Welt der Verblichenen zu betreten.  "
   "Irgendwie hast du das ungute Gefühl, dass es sich bei dieser Aufgabe "
   "darum handeln könnte, sich persönlich um dein Ableben zu kümmern."
lostsoul_dead_name_rsc = "Toter Poltergeist"
