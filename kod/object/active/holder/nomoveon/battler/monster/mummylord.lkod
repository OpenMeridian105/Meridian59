MummyLord_name_rsc = de "Der Mumienfürst"
MummyLord_desc_rsc = de \
	"Geschworen, eine Ewigkeit lang den Ruheplatz dessen zu "
	"verteidigen, dem sie im Leben dienten. Der untote Zustand "
	"eines Mumienfürsten ist das Ergebnis eines schrecklichen "
	"Fluchs oder Rituals, das dazu bestimmt ist, Verrat, Untreue "
	"oder Verbrechen noch abscheulicherer Art zu bestrafen."
MummyLord_dead_name_rsc = de "Der tote Mumienfürst"
