NeruditeTroll_name_rsc = de "Der Nerudittroll"
NeruditeTroll_desc_rsc = de \
   "Die imposante Statur dieser Kreatur spricht von Stäke und Kraft.  Sein "
   "Körper glänzt in einem grünen Metall.  Ein Geräusch wie klirrendes Metall "
   "erklingt bei jeder Bewegung."
NeruditeTroll_koc_name_rsc = de "neru humoch"
NeruditeTroll_dead_name_rsc = de "toter Nerudittroll"
