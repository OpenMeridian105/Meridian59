//////////////////////////////////////////////////////////////////////////////
NonPlayerCharacter is Monster

constants:

   include blakston.khd

resources:

classvars:

   // Mob doesn't move and cannot be attacked.
   viDefault_behavior = AI_NPC | AI_NOMOVE

   viObject_flags = OF_ATTACKABLE | OF_DISPLAY_NAME | OF_NPC

properties:

   piNameColor = NC_NPC

messages:

   UpdateDatabase()
   {
      // Wiki Export: Sold items, skills and spells by each NPC
      // List of all NPC's and a list of rooms where the NPC is in

      local i, oSkill, oSpell;

      if (plFor_Sale <> $) 
      {
         // Exclude NPCs who sell items from players, because their sell list
         // is variable and shouldn't be in the database.
         if (NOT vbSellFromInventory)
         {
            foreach i in First(plFor_sale) //items
            {
               RecordStat(STAT_NPC_SELLITEM, TAG_RESOURCE, vrName, TAG_RESOURCE,
                     Send(i,@GetName), TAG_INT, Send(i,@GetPaletteTranslation));
            }
         }
         foreach i in Nth(plFor_sale,2) //skills
         {
            oSkill = Send(SYS,@FindSkillByNum,#num=i);
            RecordStat(STAT_NPC_SELLSKILL, TAG_RESOURCE, vrName, TAG_INT, i);
         }
         foreach i in Nth(plFor_sale,3) //spells
         {
            oSpell = Send(SYS,@FindSpellByNum,#num=i);
            RecordStat(STAT_NPC_SELLSPELL, TAG_RESOURCE, vrName, TAG_INT, i);
         }
      }

      RecordStat(STAT_NPCS, TAG_RESOURCE, vrName, RESOURCE_GER, vrName, 
            TAG_RESOURCE, vrIcon, TAG_RESOURCE, vrDesc, RESOURCE_GER, vrDesc, 
            TAG_INT, viMerchant_markup);

      if (poOwner <> $)
      {
         RecordStat(STAT_NPC_ZONE, TAG_RESOURCE, vrName, TAG_INT,
            Send(poOwner,@GetRoomNum), TAG_INT, piRow, TAG_INT, piCol);
      }

      return;
   }

   CanMorphTo()
   {
      return FALSE;
   }

   EnterStateWait()
   {
      // They shouldn't have acquired a target, but to be sure...
      if poTarget <> $
         AND IsClass(poTarget,&User)
      {
         Send(poTarget,@SubtractFromMonsterChasers,
               #level=Send(self,@GetLevel),#what=self);
      }

      poTarget = $;
      piHatred = 0;

      // Leave them in the waiting state.
      Send(self,@SetState,#bit=STATE_WAIT);
      Send(self,@ClearBehavior);

      // We no longer set a move timer for NPCs.

      return;
   }

   GetHomeRoom()
   {
      // By default, return the room the NPC is in.
      if (poOwner <> $)
      {
         return Send(poOwner,@GetRoomNum);
      }

      return 0;
   }

   CountsAsMonster()
   {
      return FALSE;
   }

   IsArenaMonster()
   {
      return FALSE;
   }

end
////////////////////////////////////////////////////////////////////////////////
