JixaInnkeep_desc_rsc = de \
   "Ein Mann mit einer warmen, fröhlichen Ausstrahlung, der es liebt, "
   "Menschen lange zuzuhören, bevor er ihnen das Ohr abspricht.  Durch seine "
   "Leidenschaft für das Theater kann er stundenlang Gespräche führen.  "
   "Jorgan ist immer gut gelaunt, auch wenn er einen Kater hat , er hält alles "
   "für ein lustiges Ereignis und hält keinen Groll.  Er arbeitet hart und "
   "spielt hart."
Jixa_entry_welcome = de "HAGEL, %s%s."
