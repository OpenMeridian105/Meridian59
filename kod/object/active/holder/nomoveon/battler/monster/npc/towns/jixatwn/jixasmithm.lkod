JixaBlacksmith_name_rsc = de "Jixa Schmied"
JixaBlacksmith_desc_rsc = de \
   "Er ist ruhig und asozial und schafft es kaum ein paar Minuten im Gespräch, "
   "bevor sein behinderndes Stottern einsetzt.  Abgesehen davon, dass er "
   "aufgrund von Schlafentzug ein wenig langsam ist, ist er im Allgemeinen "
   "recht scharfsinnig.  Er bemerkt kleine Details und kann gute "
   "Schlussfolgerungen ziehen von ihnen. "
JixaBla_entry_welcome = de "H-h-hallo %s%s."
JixaBla_island_items = de "Ich handel nicht mit Nerudite Müll."
