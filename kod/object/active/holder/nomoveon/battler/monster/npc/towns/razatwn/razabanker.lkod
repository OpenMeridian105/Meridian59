RazaBanker_name_rsc = de "Gamos"
RazaBanker_desc_rsc = de \
   "Gamos verbringt seine ganze Zeit in der Gesellschaft von Geld und das "
   "sieht man. Seine Hand streichelt liebevoll das Gold, während sich ein "
   "großes vernarrtes Lächeln auf seinem Gesicht bildet. Hin und wieder schüttelt "
   "er den Beutel, um einfach nur das melodische Klingeln der Schillinge "
   "zu hören."
