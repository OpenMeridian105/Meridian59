Harbinger_name_rsc = de "Der Todbringer"
Harbinger_desc_rsc =  de \
      "Dieser schwebende Kadaver ist eine reine Verkörperung des Bösen.  Sein gliedloser "
      "Körper riecht nach Verwesung und Maden bevölkern die zahlreichen Falten seiner Haut.  "
      "Bei jeder seiner Bewegungen trieft aus seinen Poren fauliger Eiter, der langsam über seine "
      "Haut kriecht und schließlich zischend zu Boden tropft.  Der Todbringer verströmt eine Aura "
      "des kalten, unbarmherzigen Hasses."
Harbinger_relic = de "...mein Stab der Beschwörung...danke, Sterblicher..."
Harbinger_entry_welcome = de "...Ich suche es...Hast du es?... ein Relikt Qors..."
