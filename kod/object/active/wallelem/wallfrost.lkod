   WallofFrost_name_rsc = de "Frostschleier"
   WallofFrost_desc_rsc = de \
      "Der frostige Schleier verspricht jeden Hitzkopf im Handumdrehen wieder auf Zimmertemperatur zu bringen."
   WallofFrost_damage0 = de "Du widerstehst der Kälte unbeeindruckt."
   WallofFrost_damage5 = de "Dich fröstelt es etwas..."
   WallofFrost_damage10 = de "Hoffentlich hört dieses nervige Geklappere bald auf...  Moment mal.  Das bist ja du!"
   WallofFrost_damage15 = de "Du fühlst wie Tränen auf deinen Wangen zu eisigen Tropfen gefrieren.  Wie poetisch!"
   WallofFrost_damage20 = de "Jetzt, wo du deine Gliedmaßen nicht mehr spüren kannst, vermisst du wirklich das Gefühl der Kälte..."
   WallofFrost_dissipates = de "Das frostige Wölkchen löst sich in Luft auf."
