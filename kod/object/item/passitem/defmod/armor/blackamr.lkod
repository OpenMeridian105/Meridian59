BlackMetalArmor_name_rsc = de "Schwarze Metallrüstung"
BlackMetalArmor_desc_rsc = de \
"Diese Metallrüstung wird aus gealtertem Nerudit namens Schwarzmetall hergestellt, "
"welches nicht mehr über seine explosives Eigenschaften verfügt. "
"Die Platte ist bemerkenswert leichter und langlebiger als normale Rüstungen "
"und bietet ihrem Träger ausgezeichneten Schutz."
