   CowboyHat_name_rsc = de "Der Cowboyhut"
   CowboyHat_desc_rsc = de \
      "Ein Hut aus Trollhaut zusammengenäht.  Dieser Hut wurde ursprünglich "
	  "von Marinus dem Großen getragen, Vater von Rosaline Marinus.  Vor den "
	  "Tagen als Jixa gegründet wurde, hieß es, die Bauern von Berg würden "
	  "die härtesten Stachelrücken zähmen, während sie diesen Hut trugen."
