SpiritualWings_name_rsc = de "Engelsflügel"
SpiritualWings_desc_rsc = de \
   "Wie ein Weiser einst sagte: \"Ein Paar Flügel macht noch keinen Engel.\".  "
   "Obwohl diese Weisheit angeblich aus einem erhitzten Streitgespräch "
   "zwischen erwähntem Weisen und seinem notorisch schlecht gelaunten Papagei "
   "hervorging, trifft sie auch auf den Besitzer dieses Paares zu, ganz gleich "
   "wie unschuldig sie aussehen mögen.  Ganz genau.  Wir wissen alle, was du "
   "getan hast."
