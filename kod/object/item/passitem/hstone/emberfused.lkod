EmberheartFused_name_rsc = de "Verschmolzenes Glutherz"
EmberheartFused_desc_rsc = de \
	"Dieser Edelstein wird durch das Verschmelzen mehrerer Stücke Glutherz erschaffen. "
	"Er wird wegen seiner Fähigkeit geschätzt, lebendige und langanhaltende Farbstoffe zu erzeugen, "
	"die häufig abgefüllt und von Handwerkern und Kunsthandwerkern verwendet werden."
