   Sushi_name_rsc = de "Spinnenaugen Rolle"
   Sushi_desc_rsc = de \
      "Spinnenaugen in ein dünnes Blatt Brombeerstrauch gewickelt.  Wegen der "
	  "Schwierigkeit der Herstellung dieser Delikatesse, ist es unter gewöhnlichen "
	  "Leuten selten anzufinden.  Einige würden sagen, dass diese Delikatesse sogar "
	  "gut für deine Augen sein kann."

   Sushi_name_plural_rsc = de "Spinnenaugen Rollen"
