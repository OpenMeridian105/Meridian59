Truffle_name_rsc = de "Trüffel"
Truffle_name_plural_rsc = de "Stücker Trüffel"
Truffle_desc_rsc = de \
   "Die seltene Art von Trüffel wächst vorwiegend in felsigen Wäldern von Jixa "
   "und kann ausschließlich von Chupacabra mit Hilfe dessen feinen Schnauze "
   "gefunden werden. Der Trüffel gilt als eine wahre Delikatesse."
