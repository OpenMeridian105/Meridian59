////////////////////////////////////////////////////////////////////////////////
Reagent is NumberItem

constants:

   include blakston.khd

resources:

classvars:

   viItem_type = ITEMTYPE_REAGENT

properties:

   viObject_flags = OF_APPLYABLE | OF_GETTABLE

messages:

   UpdateDatabase()
   {
      local rName;

      // Wiki Export: all reagents into a table
      rName = Send(self,@GetName,#number=3);
      RecordStat(STAT_REAGENTS, TAG_RESOURCE, rName, RESOURCE_GER, rName,
            TAG_RESOURCE, vrIcon, TAG_INT, viInventory_group, TAG_INT,
            Send(self,@GetPaletteTranslation), TAG_RESOURCE, vrDesc,
            RESOURCE_GER, vrDesc, TAG_INT, viValue_average, TAG_INT, viWeight,
            TAG_INT, viBulk, TAG_INT, Send(self,@GetDatabaseFlags));

      return;
   }

   NewGameHour()
   {
      return;
   }

   ReqNewApply(what = $,apply_on = $)
   {
      if what = Send(self,@GetOwner)
         AND apply_on <> $
         AND IsClass(apply_on,&ReagentBag)
      {
         return TRUE;
      }

      return FALSE;
   }

   NewApplied(what = $,apply_on = $)
   {
      if what = Send(self,@GetOwner)
         AND apply_on <> $
         AND IsClass(apply_on,&ReagentBag)
      {
         Send(Send(what,@GetReagentBag),@NewHold,#what=self,
               #where=Send(what,@GetReagentBag),
               #number=Send(self,@GetNumber));
      }

      return;
   }

end
////////////////////////////////////////////////////////////////////////////////
