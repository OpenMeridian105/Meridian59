////////////////////////////////////////////////////////////////////////////////
Emberheart is Reagent

constants:

    include blakston.khd

resources:

    Emberheart_name_rsc = "emberheart"
    Emberheart_icon_rsc = emberheart_gray.bgf
    Emberheart_desc_rsc = \
      "One-of-a-kind gemstone that is born through the magical process of "
      "dropping a heartstone into Faren's fire.  As the heartstone "
      "is subjected to the intense heat and pressure of the forge, "
      "it undergoes a profound transformation, emerging as a smaller but "
      "infinitely more dazzling gemstone."

    Emberheart_name_plural_rsc = "emberhearts"

classvars:

    vrName = Emberheart_name_rsc
    vrIcon = Emberheart_icon_rsc

    vrDesc = Emberheart_desc_rsc

    vrName_plural = Emberheart_name_plural_rsc

    viValue_average = 500
    viWeight = 1
    viBulk = 1

    viColor = PT_GRAY_TO_RED

properties:

    piNumber = 1

messages:

   Constructor()
   {
      Send(self,@SetHeartColor,#iColor=viColor);

      propagate;
   }

    CanForge()
    {
        return TRUE;
    }

    IsExpansionItem()
    {
        return TRUE;
    }

   GetHeartstoneColor()
   {
      return viColor;
   }

   SetHeartColor(iColor=0)
   {
      piItem_flags = piItem_flags & ITEM_INVERSE_PALETTE_MASK;
      piItem_flags = piItem_flags | iColor;

      if poOwner <> $
      {
         Send(poOwner,@SomethingChanged,#what=self);
      }

      return;
   }   

end
////////////////////////////////////////////////////////////////////////////////
