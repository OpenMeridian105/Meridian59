Emberheart_name_rsc = de "Das Glutherz"
Emberheart_desc_rsc = de \
   "Ein einzigartiger Edelstein, der durch den magischen Prozess entsteht, "
   "bei dem ein Herzstein in Farens Feuer geworfen wird. Wenn der Herzstein "
   "der intensiven Hitze und dem Druck der Schmiede ausgesetzt wird, "
   "durchläuft er eine tiefgreifende Verwandlung und tritt schließlich "
   "als ein kleinerer, aber unendlich strahlenderer Edelstein hervor. "

Emberheart_name_plural_rsc = de "die Glutherzen"
