////////////////////////////////////////////////////////////////////////////////
EssenceDust is Reagent

constants:

   include blakston.khd

resources:

   include essdust.lkod

   EssenceDust_name_rsc = "essence dust"
   EssenceDust_icon_rsc = essdust.bgf
   EssenceDust_desc_rsc = \
      "Despite all life forms relying on the nexus for magic, those with "
      "lesser abilities have tried to destroy it in an order to shift the "
      "balance of power.  Essence dust are the remnants of that ancient "
      "force.  This dust may be used as a substitue for firesand, vial of "
      "solagh, shaman blood, yrxl sap, and uncut seraphym."
   EssenceDust_name_plural_rsc = "essence dust"

classvars:

   vrName = EssenceDust_name_rsc
   vrIcon = EssenceDust_icon_rsc
   vrDesc = EssenceDust_desc_rsc

   vrName_plural = EssenceDust_name_plural_rsc

   viValue_average = 1500
   viBulk = 2
   viWeight = 2

properties:

   piNumber = 3

messages:

end
////////////////////////////////////////////////////////////////////////////////
