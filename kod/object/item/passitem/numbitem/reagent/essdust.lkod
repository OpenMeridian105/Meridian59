   EssenceDust_name_rsc = de "Essenzstaub"
   EssenceDust_desc_rsc = de \
      "Trotz aller Lebensformen, die auf die Magie des Nexus angewiesen sind, "
	  "haben einige mit geringeren Fähigkeiten versucht ihn zu zerstören, um "
	  "das Kräfteverhältnis zu verschieben.  Essenzstaub sind Überreste dieser "
	  "alten Kraft.  Dieser Staub kann als Ersatz für Feuersand, Phiolen mit "
	  "Solagh, Schamanenblut, Yrxl Saft und ungeschliffenen Seraphen genutzt "
	  "werden."
   EssenceDust_name_plural_rsc = de "Essenzstaub"
