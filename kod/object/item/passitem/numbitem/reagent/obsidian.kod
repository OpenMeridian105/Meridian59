////////////////////////////////////////////////////////////////////////////////
ObsidianRock is Reagent

constants:

   include blakston.khd

resources:

   include obsidian.lkod

   ObsidianRock_name_rsc = "chunk of obsidian"
   ObsidianRock_icon_rsc = obsidian.bgf
   ObsidianRock_desc_rsc = \
      "Exotic black metal formed from aged Nerudite, that have long since "
      "have lost their magical properties.  This obsidian is heavy, useful "
      "for the creation of a blunt object."
   ObsidianRock_name_plural_rsc = "chunks of obsidian"

classvars:

   vrName = ObsidianRock_name_rsc
   vrIcon = ObsidianRock_icon_rsc
   vrDesc = ObsidianRock_desc_rsc

   vrName_plural = ObsidianRock_name_plural_rsc

   viValue_average = 200
   viWeight = 5
   viBulk = 5

properties:

   piNumber = 1

messages:

   CanForge()
   {
      return TRUE;
   }

end
////////////////////////////////////////////////////////////////////////////////
