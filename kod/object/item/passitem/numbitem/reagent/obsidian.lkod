   ObsidianRock_name_rsc = de "Obsidianbrocken"
   ObsidianRock_desc_rsc = de \
      "Exotisches schwarzes Metall aus gealtertem Nerudit, der längst seine "
	  "magischen Eigenschaften verloren hat.  Dieses Obsidian ist sehr "
	  "nützlich für die Herstellung eines stumpfen Gegenstands."
   ObsidianRock_name_plural_rsc = de "Obsidianbrocken"
