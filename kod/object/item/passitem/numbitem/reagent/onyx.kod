////////////////////////////////////////////////////////////////////////////////
OnyxRock is Reagent

constants:

   include blakston.khd

resources:

   include onyx.lkod

   OnyxRock_name_rsc = "onyx rock"
   OnyxRock_icon_rsc = onyx.bgf
   OnyxRock_desc_rsc = \
      "Exotic black metal formed from aged Nerudite, that have long since "
      "have lost their magical properties.  This onyx is oval cut and the size "
      "of a fist is in rugged condition.  This rock may be useful in the "
      "creation of a sharp object."
    
   OnyxRock_name_plural_rsc = "onyx rocks"

classvars:

   vrName = OnyxRock_name_rsc
   vrIcon = OnyxRock_icon_rsc
   vrDesc = OnyxRock_desc_rsc

   vrName_plural = OnyxRock_name_plural_rsc

   viInventory_group = 1
   viGround_group = 2

   viValue_average = 200
   viWeight = 5
   viBulk = 5

properties:

   piNumber = 1

messages:

   CanForge()
   {
      return TRUE;
   }

end
////////////////////////////////////////////////////////////////////////////////
