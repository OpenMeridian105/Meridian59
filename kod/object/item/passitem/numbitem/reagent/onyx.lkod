   OnyxRock_name_rsc = de "Onyxbrocken"
   OnyxRock_desc_rsc = de \
      "Exoitisches schwarzes Metall aus gealtertem Nerudit, das schon längst "
	  "alle magischen Eigenschaften verloren hat. Dieser Onyx ist oval geschnitten "
	  "und hat die Größe einer Faust.  Dieser Stein kann für die Herstellung "
	  "eines scharfen Gegenstands genutzt werden."
   
   OnyxRock_name_plural_rsc = de "Onyxbrocken"
