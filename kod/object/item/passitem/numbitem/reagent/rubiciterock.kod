////////////////////////////////////////////////////////////////////////////////
RubiciteRock is Reagent

constants:

   include blakston.khd

resources:

   //include obsidian.lkod

   RubiciteRock_name_rsc = "rubicite"
   RubiciteRock_icon_rsc = rubicite.bgf
   RubiciteRock_desc_rsc = \
      "Rubicite is a rare, red crystal that can be found only in very specific "
      "regions of the eastern world.  Over centuries these bright red crystals "
      "naturally have formed into the gems now known as rubies today."

   RubiciteRock_name_plural_rsc = "rubicite"

classvars:

   vrName = RubiciteRock_name_rsc
   vrIcon = RubiciteRock_icon_rsc
   vrDesc = RubiciteRock_desc_rsc

   vrName_plural = RubiciteRock_name_plural_rsc

   viValue_average = 200
   viWeight = 5
   viBulk = 5

properties:

   piNumber = 3

messages:

   CanForge()
   {
      return TRUE;
   }

end
