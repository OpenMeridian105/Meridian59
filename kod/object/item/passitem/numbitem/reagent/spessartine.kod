////////////////////////////////////////////////////////////////////////////////
SpessartineRock is Reagent

constants:

   include blakston.khd

resources:

   include spessartine.lkod

   SpessartineRock_name_rsc = "spessartine rock"
   SpessartineRock_icon_rsc = corestn.bgf
   SpessartineRock_desc_rsc = \
      "Shades of bright orange reflect off this stone as magical energies seep "
      "into the world around it.  Those in possession of this seemingly free "
      "source of power are able to substitue the spell casting requirements of "
      "any gems including emeralds, sapphires, diamonds, rubies and polished seraphym."
   SpessartineRock_name_plural_rsc = "spessartine rocks"

classvars:

   vrName = SpessartineRock_name_rsc
   vrIcon = SpessartineRock_icon_rsc
   vrDesc = SpessartineRock_desc_rsc

   vrName_plural = SpessartineRock_name_plural_rsc

   viValue_average = 1000
   viBulk = 1
   viWeight = 1

properties:

   piNumber = 2

messages:

end
////////////////////////////////////////////////////////////////////////////////
