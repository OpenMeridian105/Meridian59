   SpessartineRock_name_rsc = de "Spessartinstein"
   SpessartineRock_desc_rsc = de \
      "Schatten von leuchtendem Orange reflektieren sich von diesem Stein, "
	  "während magische Energien in die Welt herum sickern.  Diejenigen, die "
	  "Erfahrung damit haben, können diesen als Kraftquelle nutzen, um einen "
	  "Ersatz für alle Edelsteine, einschließlich Smaragde, Saphire, Diamanten, "
	  "Rubine und polierte Seraphym zu haben."
   SpessartineRock_name_plural_rsc = de "Spessartinsteine"
