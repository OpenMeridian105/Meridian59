////////////////////////////////////////////////////////////////////////////////
TheurgicRemnant is Reagent

constants:

   include blakston.khd

resources:

   //include windleaf.lkod

   TheurgicRemnant_name_rsc = "theurgic remnant"
   TheurgicRemnant_icon_rsc = thurelic.bgf
   TheurgicRemnant_desc_rsc = \
      "A power flows through every creature, but when a life force ends, magical "
      "energies flow freely from the remains.  Ancient wizards have been able to "
      "harness this flowing magic through the use of these artifacts.  There are "
      "small circles who refuse to accept any powers bestowed by these relics "
      "as their true origins are still unknown.  This theurgic remnant may be "
      "used a substitue reagent for any spell that requires the life force of a "
      "former creature.  This includes fairy wings, orc teeth, dragonfly eyes, "
      "kriipa claws, dark angel feathers and blue dragon scales."
   TheurgicRemnant_name_plural_rsc = "theurgic remnants"

classvars:

   vrName = TheurgicRemnant_name_rsc
   vrIcon = TheurgicRemnant_icon_rsc
   vrDesc = TheurgicRemnant_desc_rsc

   vrName_plural = TheurgicRemnant_name_plural_rsc

   viValue_average = 2000
   viWeight = 5
   viBulk = 5

properties:

   piNumber = 1

messages:

end
////////////////////////////////////////////////////////////////////////////////
