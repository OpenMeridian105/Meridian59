   TheurgicRemnant_name_rsc = de "Theurgierest"
   TheurgicRemnant_desc_rsc = de \
      "Eine Kraft fließt durch jede Kreatur, aber wenn eine Lebenskraft endet, "
	  "fließen die magischen Energien aus den Überresten.  Alte Zauberer konnten "
	  "dies Magie durch Verwendung dieser Artefakte nutzen.  Es gibt einige "
	  "die nicht an die Kräfte dieser Relikte glauben, da es nicht eindeutig "
	  "bewiesen ist.  Dieser Theurgierest kann als Ersatz für Reagenzien, die "
	  "eine Art Lebenskraft benötigen. Dies beinhaltet Feenflügel, Orkzähne, "
	  "Drachenfliegenaugen, Kriipaklauen, Feder eines dunklen Engels und "
	  "Drachenschuppen."
   TheurgicRemnant_name_plural_rsc = de "Theurgiereste"
