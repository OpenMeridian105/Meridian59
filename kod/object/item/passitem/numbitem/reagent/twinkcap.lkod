   TwinkleCap_name_rsc = de "funkelnder Kappenpilz"
   TwinkleCap_desc_rsc = de \
      "Impulse mit leuchtenden Farben, magischer Energie strahlen und funkeln "
	  "aus dem funkelnden Kappenpilz.  Nur wer in der Lage ist, sich mit diesen "
	  "Energien zu verbinden, kann sie zum eigenen Vorteil verwenden. Dieser "
	  "Pilz kann als Reagenz f³r jeden Zauber genutzt werden, der die "
	  "Verwendung von Pilzen erfordert."
   TwinkleCap_name_plural_rsc = de "funkelnde Kappenpilze"
