////////////////////////////////////////////////////////////////////////////////
WindrootLeaf is Reagent

constants:

resources:

   include windleaf.lkod

   WindrootLeaf_name_rsc = "windroot leaf"
   WindrootLeaf_icon_rsc = leaf.bgf
   WindrootLeaf_desc_rsc = \
      "When this leaf passes through the wind, it vibrates with a soft humming "
      "sound.  This rare leaf is said to be a potent reagent with versatile "
      "properties.  This special reagent may be substitued in place of "
      "elderberries, entroot berries, herb, rainbow fern and web moss."
   WindrootLeaf_name_plural_rsc = "windroot leaves"

classvars:

   vrName = WindrootLeaf_name_rsc
   vrIcon = WindrootLeaf_icon_rsc
   vrDesc = WindrootLeaf_desc_rsc

   vrName_plural = WindrootLeaf_name_plural_rsc

   viValue_average = 500
   viWeight = 2
   viBulk = 3

properties:

   piNumber = 2

messages:

end
////////////////////////////////////////////////////////////////////////////////
