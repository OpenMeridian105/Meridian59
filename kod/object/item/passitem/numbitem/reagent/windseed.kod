////////////////////////////////////////////////////////////////////////////////
WindrootSeed is Reagent

constants:

   include blakston.khd

resources:

   include windseed.lkod

   WindrootSeed_name_rsc = "windroot seed"
   WindrootSeed_icon_rsc = seed.bgf
   WindrootSeed_desc_rsc = \
      "These seeds can be planted on a soft soil to grow windroot leaves.  "
   WindrootSeed_name_plural_rsc = "windroot seeds"

classvars:

   vrName = WindrootSeed_name_rsc
   vrIcon = WindrootSeed_icon_rsc
   vrDesc = WindrootSeed_desc_rsc

   vrName_plural = WindrootSeed_name_plural_rsc

   viValue_average = 60
   viBulk = 1
   viWeight = 1

properties:

   piNumber = 1

messages:

end
////////////////////////////////////////////////////////////////////////////////
