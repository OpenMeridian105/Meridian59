LoadoutScroll_label_name_rsc = de "Schriftrolle des Ausladens"
LoadoutScroll_desc_rsc = de \
   "Diese Schriftrolle aktiviert die Verbindung mit den Truhen deiner Gildenhalle "
   "und deinem persönlichen Lager und erlaubt es dir auf diese Weise, die dort "
   "hinterlegten Ausrüstungsgegenstände und Reagenzien in deinem Inventar erscheinen "
   "zu lassen.  Die Liste an Gegenständen, die in dein Inventar überführt werden "
   "sollen, muss zuvor bei Frular registriert worden sein."
