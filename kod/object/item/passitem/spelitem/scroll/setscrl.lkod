SetScroll_label_name_rsc = de "Schriftrolle des Inventars"
SetScroll_desc_rsc = de \
   "Diese Schriftrolle erlaubt es dir, eine Momentaufnahme deines Inventars "
   "bei Frular zu registrieren.  Mit der späteren Verwendung einer Schriftrolle "
   "des Ausladens kannst du dein Inventar anschließend mit den Vorräten deiner "
   "Gildenkisten und deines persönlichen Lagers aus der Ferne wieder aufstocken, "
   "so dass es dem registrierten Inventarzustand entspricht."
