   BlackAxe_name_rsc = de "die schwarze Metallaxt"
   BlackAxe_desc_rsc = de \
      "Schwer und messerscharf, diese tolle Axt ist extrem gefährlich. "
	  "Die Axt kann die dicke Haut von Trollen nicht spalten, aber "
	  "fleischigere Kreaturen werden nciht so viel Glück haben.  "
	  "Diese Axt wurde mit einem seltenen schwarzen Metall gefertigt."
