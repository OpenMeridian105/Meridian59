   BlackHammer_name_rsc = de "der schwarze Metallhammer"
   BlackHammer_desc_rsc = de \
      "Schwer und stumpf, dieser Hammer ist eine mächtige "
	  "Waffe, die Fleisch und Knochen zerbrechen kann.  Es ist "
	  "die bevorzugte Waffe des Bergbauvolkes aus Jasper.  "
	  "Dieser Hammer wurde aus einem seltenen schwarzen Metall "
	  "gefertigt."
