Dagger_name_rsc = de "Der Dolch"
Dagger_desc_rsc = de \
   "Elegant und dennoch unscheinbar, besitzt dieser schlanke Dolch eine tödliche Schneide, die "
   "schnell Gegner erledigen kann. Sein wendiges Design macht ihn zu einem präzisen Instrument, "
   "perfekt für schnelle und lautlose Angriffe."
