   IceSword_name_rsc = de "Frostklinge"
   IceSword_desc_rsc = de \
      "Dieses Schwert ist sehr kalt, wenn du es berührst, fühlst du eine kühle "
	  "Brise von Vertrauen, die deine Seele erfüllt.  Diese Eisklinge hat "
	  "sicherlich viele Leben gekostet, und wirst du jedem gerecht werden "
	  "der es wagt, seinen Meister herauszufordern?"
