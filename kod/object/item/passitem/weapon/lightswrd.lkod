   LightningSword_name_rsc = de "Das Blitzschwert"
   LightningSword_desc_rsc = de \
      "Geheimnisvoll und faszinierend anzuschauen, diese feine Waffe funkelt "
	  "heftig und hin und wieder läuft ein gefährlicher Strom von Elektrizität "
	  "die Klinge der Länge entlang.  Wenn du dieses Schwert in deinem Besitz "
	  "hast, hast Du ein Gefühl von Macht, wie du es nie zuvor gespürt hast."
