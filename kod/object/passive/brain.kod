   TS_MURDER = 3
   TS_FIGHT_DEFEND_VICTIM = 4
   TS_FIGHT_ASSIST_VICTIM = 5
   TS_FIGHT_DEFEND_ATTACKER = 6
   TS_FIGHT_ASSIST_ATTACKER = 7

