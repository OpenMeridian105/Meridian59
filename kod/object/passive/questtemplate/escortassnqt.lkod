EscortAssassination_name_rsc = de "Schüler Auftrag: Ermordung"
EscortAssassination_desc_rsc = de \
   "Luisane d'Ile kämpft mit dem Zustrom von Reisenden, die mit Jixa handeln.  "
   "Finde einen Reisenden und eliminiere sie."
   
