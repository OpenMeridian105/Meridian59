   NeruGolemQuest_name_rsc = de "Golem-Erstellung"
 
   NeruGolemQuest_desc_rsc = de \
      "Für die Golems ist nur wenig bekannt, außer dass sie vom Menschen erschaffen wurden.  "
      "Als Werkzeug für den großen Krieg und zum Schutz von Berg verwendet.  "
      "Sie sind jetzt wegen ihrer mächtigen Stärke weggesperrt.  "
      "Bastiane d'Ile träumt davon, seinen eigenen Golem zu haben, damit er nicht länger"
      "muss funktionieren.  Hilf mit, Informationen über die Entstehung der Golems zu sammeln und"
      "Erstelle selbst einen."
 
   NeruGolemQuest_return_rsc = de \
      "Kehren Sie zu% s zurück und teilen Sie% s mit, dass die Aufgabe abgeschlossen wurde."
 
   NeruGolemQuest_completed = de \
      "Du hast erfolgreich ein Golem gekauft, aber es war viel zu mächtig, um ihn zu kontrollieren."
 
   // Ressourcen suchen.
   nerugolemquest_trigger = de "Golems"
   nerugolemquest_assign_2 = de \
      "Die Golems sind von Menschenhand geschaffen, oder? Sie denken, als Werkzeug würden wir sie benutzen.  "
      "Sie sollen uns dienen, anstatt sie in diesen Höhlen zu verschließen.  "
      "Wir sollten wie ein König leben und keinen eigenen Tag arbeiten müssen"
      "..In unserem Leben. Ich wette, ya ~ wir unsere eigenen Golem machen können ... es kann nicht sein, dass"
      "hart ... vielleicht könntest du einen umhauen und herausfinden, wie sie gebaut sind?"
 
   NeruGolemQuest_node2_rsc = de \
      "Bastiane d'Ile will herausfinden, wie ein Golem gebaut wird, vielleicht von"
