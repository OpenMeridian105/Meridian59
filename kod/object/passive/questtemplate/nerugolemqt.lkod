   NeruGolemQuest_node3_rsc = de \
      "Rosaline Marinus 'Vater war ein Meisterschmied.  Besuchen Sie sie, wie sie kann.  "
      "mit dem Ursprung der Golems vertraut sein."
   nerugolemquest_assign_3 = de \
      "Großartiger Jala ?! Du hast es geschafft, einen auszuschalten? Mein Traum! Mein vv-ganz eigener"
      "Golem! Es kann doch in meiner Reichweite sein! Ah, ich dachte"
      "Einer könnte uns helfen, aber siehst du ... ich bin kein E-Experte ..."
      "Vielleicht solltest du den Färber bei Jixa suchen . Ihr Vater war"
      "Eine großartige Fälscherin, vielleicht hat sie ihr Wissen weitergegeben."
   nerugolemquest_failure_3 = de \
      "Betreff: Golem-Erstellung \n"
      "Sorry Kumpel, ich habe ein bisschen zu viel getrunken."
      "Ignoriere meine Rede von einem Golem."
 
   NeruGolemQuest_node4_rsc = de \
      "Die Schaffung von Golems ist von dem Xeochicatls entstanden ."
      "Geh und töte einen mächtigen Ne'xeochicatl und erstatte Rosaline Marinus Bericht."
   nerugolemquest_assign_4 = de \
      "Sie haben einen Golem besiegt? Sie müssen ganz der Krieger sein."
      "Mein Vater würde Ursprungsgeschichten dieser Maschinen teilen."
      "Er erwähnte, dass Herzsteine magische Eigenschaften haben und in"
      "obwohl die erschaffung von golems von einem einst mächtigen alchemisten. obwohl die"
      "Die eigentliche Methode ist immer noch ein Rätsel. Jenseits von Berg durch die"
      "Es gibt Legenden von einem"
      "Riese Xeochicatl . Es könnte sein, dass diese Kreatur die Quelle für"
      "ihre Macht. Vielleicht hast du besseres Glück, wenn du versuchst, eine von ihnen zu zerlegen."
      "diese Sachen."
   nerugolemquest_failure_4 = de \
      "Betreff: Golem-Erstellung \n"
      "Ich hätte auch vor der Stärke des Xeochicatl warnen sollen ."
      "Ich hoffe du lebst noch da draußen!"
 
   NeruGolemQuest_node5_rsc = de \
