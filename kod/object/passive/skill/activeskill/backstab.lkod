   Backstab_name_rsc = de "Hinterhalt"
   Backstab_desc_rsc = de \
      "Hinterhalt ist eine tödliche Technik, die von heimlichen Attentätern bevorzugt wird. Sie besteht darin, schnell verwundbare Punkte aus dem Schatten heraus zu treffen und präzisen und verheerenden Schaden anzurichten.  "
      "\n\nHINWEIS: Dies ist eine 'aktive' Fähigkeit, die manuell mit dem Befehl ‘perform Hinterhalt’ oder mit einer Taste ausgeführt werden muss."

   Backstab_bad_target = de "Du entscheidest dich, deinen Hinterhalt für etwas Besseres aufzusparen."

   Backstab_cannot = de "Diese Waffe ist für einen Hinterhalt ungeeignet."
