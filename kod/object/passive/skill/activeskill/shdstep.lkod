ShadowStep_name_rsc = de "Schattenschritt"
ShadowStep_desc_rsc = de \
   "Eine dunkle und tödliche Technik, die es dem Schurken erlaubt, die Schatten "
   "nach seinem Willen zu beugen und hinter einen Feind in kurzer Entfernung zu blinzeln.  "
   "\n\nHINWEIS: Dies ist eine 'aktive' Fähigkeit, die manuell "
   "mit dem Befehl 'Schattenschritt ausführen' oder mit einer Taste ausgeführt werden muss."
ShadowStep_use = de "Du trittst geschickt hinter dein Ziel!"
ShadowStep_fail_rsc = de "Es ist nicht genug Platz, um hinter dein Ziel zu treten."
ShadowStep_target_rsc = de "Irgendwie fühlst du dich ausmanövriert."
