slash_name_rsc = de "Hiebfertigkeit"
slash_desc_rsc = de \
	"Der Hieb ist eine von mehreren Arten, eine Waffe im Kampf zu führen, "
   "und ermöglicht einem wendigen Kämpfer, seine unbeholfenen Gegner mit einer "
   "Klingenwaffe auszumanövrieren."
   
slash_skill_intro = de \
	"Waffenfertigkeiten Stufe 3: Eine grundlegende Fertigkeit im "
   "bewaffneten Kampf, die erforderlich ist, um Klingenwaffen wie Krummsäbel "
   "und Macheten richtig zu verwenden."
	