slash_name_rsc = de "Schwingen"
slash_desc_rsc = de "Das Schwingen einer Waffe ist eine der vier grundlegenden Techniken "
   "diese zu führen und erlaubt es einem agilen Kämpfer, seinem Gegner mit einer scharfen "
   "Klinge furchtbare Schnittwunden beizubringen."

slash_skill_intro = de "Waffenfertigkeiten Zirkel 1: Eine grundlegende Waffenfertigkeit, "
   "die dazu benötigt wird, um Schneidewaffen wie den Säbel effektiv zu verwenden."
