stab_name_rsc = de "Zustechen"
stab_desc_rsc = de "Das Stechen mit einer Waffe ist eine der vier grundlegenden Techniken "
   "diese zu führen und erlaubt es einem agilen und zielgenauen Kämpfer, seine Gegner mit "
   "einer kurzen Klinge zu überwältigen."

stab_skill_intro = de "Waffenfertigkeiten Zirkel 1: Eine grundlegende Waffenfertigkeit, "
   "die dazu benötigt wird, um Waffen wie Dolche oder Kurzschwerter effektiv einzusetzen."
