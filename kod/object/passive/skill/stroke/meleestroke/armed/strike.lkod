strike_name_rsc = de "Zuschlagen"
strike_desc_rsc = de "Das Zuschlagen mit einer Waffe ist eine der vier grundlegenden Techniken "
   "diese zu führen und erlaubt es einem kräftigen Kämpfer, seine Gegner mit schweren Waffen zu "
   "zerschmettern."

strike_skill_intro = de "Waffenfertigkeiten Zirkel 1: Eine grundlegende Waffenfertigkeit, "
   "die dazu benötigt wird, um schwere Waffen wie Streitkolben, Hämmer oder Äxte zu führen."
