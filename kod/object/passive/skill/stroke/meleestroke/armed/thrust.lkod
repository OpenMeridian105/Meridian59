thrust_name_rsc = de "Zustechen"
thrust_desc_rsc = de "Das Zustechen mit einer Waffe ist eine der vier grundlegenden Techniken "
   "diese zu führen und erlaubt es einem zielgenauen Kämpfer, seine Gegner mit einer spitzen "
   "Waffe zu durchlöchern."

thrust_skill_intro = de "Waffenfertigkeiten Zirkel 1: Eine grundlegende Waffenfertigkeit, "
   "die dazu benötigt wird, um Stichwaffen, wie es die meisten Schwerter sind, effektiv zu führen."
