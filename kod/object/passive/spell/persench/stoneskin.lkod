stoneskin_name_rsc = de "Steinhaut"
stoneskin_desc_rsc = de \
   "Verhärtet die Haut des Ziels zu extrem hartem, aber flexiblem Stein "
   "und verringert so die Effektivität von Waffenangriffen."
stoneskin_already_affected = de \
   "Die Haut des Ziels wurde bereits geändert, sodass dein Zauber "
   "keine Auswirkungen mehr hat."
stoneskin_on = de "Deine Haut verhärtet sich zu Stein."
stoneskin_off = de "Der Stein zerbröckelt von deiner Haut."
