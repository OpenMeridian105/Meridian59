////////////////////////////////////////////////////////////////////////////////
SpinebeastBossTreasure is TreasureType

constants:

   include blakston.khd

classvars:

   viTreasure_num = TID_SPINEBEAST_BOSS

   viMinItemDrop = 15

properties:

   piItem_att_chance = 10
   piDiff_seed = 10

messages:

   Constructed()
   {
      plTreasure = [ [ &ObsidianRock, 25 ],
                     [ &OnyxRock, 20 ],
                     [ &JalaNecklace, 10 ],
                     [ &WindrootLeaf, 10],
                     [ &SpessartineRock, 9 ],
                     [ &OrcShield, 5 ],
                     [ &RingInvisibility, 3 ],
                     [ &ChestKey, 3 ],
                     [ &TwinkleCap, 3 ],
                     [ &GoldSword, 3 ],
                     [ &TrueLute, 6 ],
                     [ &EssenceDust, 2 ],
                     [ &TheurgicRemnant, 1 ]
                   ];

      propagate;
   }

end
////////////////////////////////////////////////////////////////////////////////
