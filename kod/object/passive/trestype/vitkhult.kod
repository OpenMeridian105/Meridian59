////////////////////////////////////////////////////////////////////////////////
VitkhulTreasure is TreasureType

constants:

   include blakston.khd

classvars:

   viTreasure_num = TID_VITKHUL

properties:

   piItem_att_chance = 10
   piDiff_seed = 10

messages:

   InitTreasureLists()
   {
      plTreasure = [ [ &InkyCap, 20],
                     [ &DarkAngelFeather, 20],
                     [ &BlueDragonScale, 17],
                     [ &GrayMushroom, 14],
                     [ &TheurgicRemnant, 12],
                     [ &Knife, 8],
                     [ &Machete, 8],
                     [ &IceSword, 3],
                     [ &HoldWand, 1]
                   ];

      propagate;
   }

end
////////////////////////////////////////////////////////////////////////////////
