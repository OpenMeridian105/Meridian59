   NecromancerInvasion_start_msg = de \
      "~B~k[Event]~n ~B~v Die Realität wird aufgerissen, und ein dunkles Portal öffnet sich, um eine Armee untoter Krieger aus der Stadt Brax zu enthüllen. An ihrer Spitze steht die Schlange Königin, während sie ihre Augen auf den Flaggenmast von %s richtet"

   NecromancerInvasion_end_msg = de \
      "~B~k[Event]~n ~B~v Ein Portal zuckt und stürzt mit einer Explosion dunkler Energie zusammen, während Joline und die Nekromanten gezwungen sind, in die Stadt Brax zurückzukehren. Der Flaggenmast von %s steht dank der Tapferkeit seiner Verteidiger, die die angreifenden Kräfte der Dunkelheit abgewehrt haben."
      