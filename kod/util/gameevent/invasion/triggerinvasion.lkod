   TriggeredInvasion_start_msg = de \
      "~B~k[Event]~n ~B~v Ein Todbringer ist in der Nähe von %s erschienen und hat begonnen, "
      "seine unheiligen Diener zu beschwören.  Shal'ille warnt die Bewohner Meridians vor ihrem "
      "grotesken und unvorhersehbaren Verhalten."

   TriggeredInvasion_end_msg = de "~B~k[Event]~n ~B~v Die Heerscharen des Todbringers ziehen sich zurück."
